{
    "meta": {
        "name": "Connect Lobby",
        "version": "1.0.0",
        "author": "Game Builder"
    },
    "stage": {
        "grid": {
            "cols": 64,
            "rows": 40,
            "cellSize": 20,
            "snapToGrid": true,
            "visible": false,
            "backgroundColor": "#1a1a2e"
        }
    },
    "objects": [
        {
            "id": "game-loop",
            "name": "GameLoop",
            "className": "TGameLoop",
            "x": 0,
            "y": 0,
            "width": 0,
            "height": 0,
            "Tasks": {
                "onRoomCreated": "HandleRoomCreated",
                "onRoomJoined": "HandleRoomJoined",
                "onPlayerJoined": "HandlePlayerJoined"
            }
        },
        {
            "id": "header",
            "name": "Header",
            "className": "TGameHeader",
            "title": "🎮 Multiplayer Connect",
            "x": 0,
            "y": 1,
            "width": 32,
            "height": 2,
            "style": {
                "backgroundColor": "#16213e",
                "color": "#4fc3f7"
            }
        },
        {
            "id": "btn-create",
            "name": "BtnCreate",
            "className": "TButton",
            "caption": "🎲 Raum erstellen",
            "x": 10,
            "y": 6,
            "width": 12,
            "height": 3,
            "style": {
                "backgroundColor": "#4caf50",
                "color": "white",
                "borderRadius": "8px"
            },
            "Tasks": {
                "onClick": "CreateRoomTask"
            }
        },
        {
            "id": "label-or",
            "name": "LabelOr",
            "className": "TLabel",
            "text": "— oder —",
            "x": 10,
            "y": 10,
            "width": 12,
            "height": 2,
            "alignment": "center",
            "style": {
                "color": "#888888",
                "backgroundColor": "transparent"
            }
        },
        {
            "id": "input-code",
            "name": "InputCode",
            "className": "TTextInput",
            "text": "",
            "placeholder": "RAUM CODE",
            "maxLength": 6,
            "uppercase": true,
            "x": 10,
            "y": 13,
            "width": 8,
            "height": 3,
            "style": {
                "backgroundColor": "#2a2a2a",
                "color": "white",
                "border": "2px solid #444",
                "borderRadius": "4px",
                "fontSize": "20px",
                "textAlign": "center"
            }
        },
        {
            "id": "btn-join",
            "name": "BtnJoin",
            "className": "TButton",
            "caption": "Beitreten",
            "x": 19,
            "y": 13,
            "width": 5,
            "height": 3,
            "style": {
                "backgroundColor": "#2196f3",
                "color": "white",
                "borderRadius": "8px"
            },
            "Tasks": {
                "onClick": "JoinRoomTask"
            }
        },
        {
            "id": "status-label",
            "name": "StatusLabel",
            "className": "TLabel",
            "text": "Warte auf Verbindung...",
            "x": 0,
            "y": 20,
            "width": 32,
            "height": 2,
            "alignment": "center",
            "style": {
                "color": "#ff9800",
                "backgroundColor": "transparent"
            }
        }
    ],
    "tasks": [
        {
            "name": "CreateRoomTask",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ActionCreateRoom"
                },
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Erstelle Raum..."
                    }
                }
            ]
        },
        {
            "name": "JoinRoomTask",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ActionJoinRoom"
                },
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Verbinde..."
                    }
                }
            ]
        },
        {
            "name": "HandleRoomCreated",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Raum: ${roomCode} - Warte auf P2..."
                    }
                },
                {
                    "type": "property",
                    "target": "BtnCreate",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "BtnJoin",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "InputCode",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "LabelOr",
                    "changes": {
                        "visible": false
                    }
                }
            ]
        },
        {
            "name": "HandleRoomJoined",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Verbunden! Starte Pong..."
                    }
                },
                {
                    "type": "wait",
                    "duration": 1000
                },
                {
                    "type": "action",
                    "name": "StartPong"
                }
            ]
        },
        {
            "name": "HandlePlayerJoined",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Spieler 2 da! Starte Pong..."
                    }
                },
                {
                    "type": "wait",
                    "duration": 1000
                },
                {
                    "type": "action",
                    "name": "StartPong"
                }
            ]
        }
    ],
    "actions": [
        {
            "name": "ActionCreateRoom",
            "type": "create_room"
        },
        {
            "name": "ActionJoinRoom",
            "type": "join_room",
            "source": "InputCode"
        },
        {
            "name": "StartPong",
            "type": "navigate",
            "target": "pong.json",
            "params": {
                "mode": "multi"
            }
        }
    ],
    "variables": [
        {
            "name": "roomCode",
            "defaultValue": "----"
        }
    ]
}