    "actions": [
        {
            "name": "ResetBallPos",
            "type": "property",
            "target": "Ball",
            "changes": {
                "x": 31,
                "y": 36,
                "velocityX": 0.15,
                "velocityY": -0.2
            }
        },
        {
            "name": "IncScore",
            "type": "increment",
            "target": "Score1",
            "changes": {
                "text": 50
            }
        },
        {
            "name": "HideSelf",
            "type": "property",
            "target": "self",
            "changes": {
                "style.visible": false,
                "collisionEnabled": false
            }
        },
        {
            "name": "BounceOtherY",
            "type": "negate",
            "target": "other",
            "changes": {
                "velocityY": true
            }
        },
        {
            "name": "BounceOtherX",
            "type": "negate",
            "target": "other",
            "changes": {
                "velocityX": true
            }
        },
        {
            "name": "BounceSelfY",
            "type": "negate",
            "target": "self",
            "changes": {
                "velocityY": true
            }
        },
        {
            "name": "BounceSelfX",
            "type": "negate",
            "target": "self",
            "changes": {
                "velocityX": true
            }
        }
    ],
    "tasks": [
        {
            "name": "ResetBall",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ResetBallPos"
                }
            ]
        },
        {
            "name": "HandleWallHit",
            "actionSequence": [
                {
                    "type": "condition",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "bottom"
                    },
                    "thenTask": "ResetBall"
                }
            ]
        },
        {
            "name": "HandlePaddleHit",
            "actionSequence": [
                {
                    "type": "condition",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "bottom"
                    },
                    "thenAction": "BounceSelfY"
                }
            ]
        },
        {
            "name": "HandleBrickHit",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "HideSelf"
                },
                {
                    "type": "action",
                    "name": "IncScore"
                },
                {
                    "type": "condition",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "top"
                    },
                    "thenAction": "BounceOtherY"
                },
                {
                    "type": "condition",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "bottom"
                    },
                    "thenAction": "BounceOtherY"
                },
                {
                    "type": "condition",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "left"
                    },
                    "thenAction": "BounceOtherX"
                },
                {
                    "type": "condition",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "right"
                    },
                    "thenAction": "BounceOtherX"
                }
            ]
        }
    ],
    "variables": []
}