{
    "meta": {
        "name": "Game Lobby",
        "version": "1.1.0",
        "author": "Game Builder"
    },
    "stage": {
        "grid": {
            "cols": 64,
            "rows": 40,
            "cellSize": 20,
            "snapToGrid": true,
            "visible": false,
            "backgroundColor": "#1a1a2e"
        }
    },
    "objects": [
        {
            "id": "game-loop",
            "name": "GameLoop",
            "className": "TGameLoop",
            "x": 0,
            "y": 0,
            "width": 0,
            "height": 0,
            "Tasks": {
                "onRoomCreated": "HandleRoomCreated",
                "onRoomJoined": "HandleRoomJoined",
                "onPlayerJoined": "HandlePlayerJoined"
            }
        },
        {
            "id": "header-1",
            "name": "Header",
            "className": "TGameHeader",
            "x": 0,
            "y": 0,
            "width": 32,
            "height": 2,
            "title": "🎮 Game Lobby",
            "fontSize": 24,
            "fontWeight": "bold",
            "style": {
                "backgroundColor": "#16213e",
                "color": "#4fc3f7",
                "borderWidth": 0
            }
        },
        {
            "id": "card-pong",
            "name": "PongCard",
            "className": "TGameCard",
            "x": 4,
            "y": 4,
            "width": 6,
            "height": 6,
            "gameName": "Pong",
            "gameFile": "pong.json",
            "waitingCount": 0,
            "style": {
                "backgroundColor": "#2a2a2a",
                "borderColor": "#4fc3f7",
                "borderWidth": 2,
                "color": "#ffffff"
            },
            "Tasks": {
                "onSingleClick": "PlaySingle",
                "onMultiClick": "PlayMultiPong"
            }
        },
        {
            "id": "label-help",
            "name": "HelpLabel",
            "className": "TLabel",
            "x": 4,
            "y": 20,
            "width": 24,
            "height": 2,
            "text": "Wähle ein Spiel und klicke auf Single oder Multiplayer",
            "fontSize": 12,
            "alignment": "left",
            "style": {
                "backgroundColor": "transparent",
                "color": "#888888",
                "borderWidth": 0
            }
        },
        {
            "id": "overlay-bg",
            "name": "OverlayBG",
            "className": "TPanel",
            "x": 0,
            "y": 0,
            "width": 32,
            "height": 24,
            "visible": false,
            "style": {
                "backgroundColor": "#000000",
                "borderWidth": 0
            }
        },
        {
            "id": "overlay-title",
            "name": "OverlayTitle",
            "className": "TLabel",
            "text": "MULTIPLAYER CONNECT",
            "x": 0,
            "y": 4,
            "width": 32,
            "height": 2,
            "visible": false,
            "alignment": "center",
            "fontSize": 24,
            "style": {
                "color": "#4fc3f7",
                "backgroundColor": "transparent",
                "fontWeight": "bold"
            }
        },
        {
            "id": "btn-create",
            "name": "BtnCreate",
            "className": "TButton",
            "caption": "🎲 Raum erstellen",
            "x": 10,
            "y": 8,
            "width": 12,
            "height": 3,
            "visible": false,
            "style": {
                "backgroundColor": "#4caf50",
                "color": "white",
                "borderRadius": "8px"
            },
            "Tasks": {
                "onClick": "CreateRoomTask"
            }
        },
        {
            "id": "input-code",
            "name": "InputCode",
            "className": "TTextInput",
            "text": "",
            "placeholder": "RAUM CODE",
            "maxLength": 6,
            "uppercase": true,
            "x": 10,
            "y": 12,
            "width": 8,
            "height": 3,
            "visible": false,
            "style": {
                "backgroundColor": "#2a2a2a",
                "color": "white",
                "border": "2px solid #444",
                "borderRadius": "4px",
                "fontSize": "20px",
                "textAlign": "center"
            }
        },
        {
            "id": "btn-join",
            "name": "BtnJoin",
            "className": "TButton",
            "caption": "Beitreten",
            "x": 19,
            "y": 12,
            "width": 3,
            "height": 3,
            "visible": false,
            "style": {
                "backgroundColor": "#2196f3",
                "color": "white",
                "borderRadius": "8px"
            },
            "Tasks": {
                "onClick": "JoinRoomTask"
            }
        },
        {
            "id": "status-label",
            "name": "StatusLabel",
            "className": "TLabel",
            "text": "Wähle eine Option...",
            "x": 0,
            "y": 16,
            "width": 32,
            "height": 2,
            "visible": false,
            "alignment": "center",
            "style": {
                "color": "#ff9800",
                "backgroundColor": "transparent"
            }
        },
        {
            "id": "btn-cancel",
            "name": "BtnCancel",
            "className": "TButton",
            "caption": "Abbrechen",
            "x": 12,
            "y": 20,
            "width": 8,
            "height": 2,
            "visible": false,
            "style": {
                "backgroundColor": "#d32f2f",
                "color": "white",
                "borderRadius": "8px"
            },
            "Tasks": {
                "onClick": "HideOverlayTask"
            }
        }
    ],
    "actions": [
        {
            "name": "NavigateToPong",
            "type": "navigate",
            "target": "pong.json"
        },
        {
            "name": "SetNextGamePong",
            "type": "set_variable",
            "variable": "nextGame",
            "value": "pong.json"
        },
        {
            "name": "NavigateToNextGame",
            "type": "navigate",
            "target": "${nextGame}",
            "params": {
                "mode": "multi"
            }
        },
        {
            "name": "ActionCreateRoom",
            "type": "create_room",
            "game": "${nextGame}"
        },
        {
            "name": "ActionJoinRoom",
            "type": "join_room",
            "source": "InputCode"
        }
    ],
    "tasks": [
        {
            "name": "PlaySingle",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "NavigateToPong"
                }
            ]
        },
        {
            "name": "PlayMultiPong",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "SetNextGamePong"
                },
                {
                    "type": "task",
                    "name": "ShowOverlayTask"
                }
            ]
        },
        {
            "name": "ShowOverlayTask",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "PongCard",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "HelpLabel",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "OverlayBG",
                    "changes": {
                        "visible": true
                    }
                },
                {
                    "type": "property",
                    "target": "OverlayTitle",
                    "changes": {
                        "visible": true
                    }
                },
                {
                    "type": "property",
                    "target": "BtnCreate",
                    "changes": {
                        "visible": true
                    }
                },
                {
                    "type": "property",
                    "target": "InputCode",
                    "changes": {
                        "visible": true
                    }
                },
                {
                    "type": "property",
                    "target": "BtnJoin",
                    "changes": {
                        "visible": true
                    }
                },
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "visible": true,
                        "text": "Wähle eine Option..."
                    }
                },
                {
                    "type": "property",
                    "target": "BtnCancel",
                    "changes": {
                        "visible": true
                    }
                }
            ]
        },
        {
            "name": "HideOverlayTask",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "OverlayBG",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "OverlayTitle",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "BtnCreate",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "InputCode",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "BtnJoin",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "BtnCancel",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "PongCard",
                    "changes": {
                        "visible": true
                    }
                },
                {
                    "type": "property",
                    "target": "HelpLabel",
                    "changes": {
                        "visible": true
                    }
                }
            ]
        },
        {
            "name": "CreateRoomTask",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ActionCreateRoom"
                },
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Erstelle Raum..."
                    }
                }
            ]
        },
        {
            "name": "JoinRoomTask",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ActionJoinRoom"
                },
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Verbinde..."
                    }
                }
            ]
        },
        {
            "name": "HandleRoomCreated",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Raum: ${roomCode} - Warte auf P2..."
                    }
                },
                {
                    "type": "property",
                    "target": "BtnCreate",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "BtnJoin",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "InputCode",
                    "changes": {
                        "visible": false
                    }
                },
                {
                    "type": "property",
                    "target": "OverlayTitle",
                    "changes": {
                        "text": "WARTE AUF SPIELER..."
                    }
                }
            ]
        },
        {
            "name": "HandleRoomJoined",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "Verbunden! Start..."
                    }
                },
                {
                    "type": "wait",
                    "duration": 1000
                },
                {
                    "type": "action",
                    "name": "NavigateToNextGame"
                }
            ]
        },
        {
            "name": "HandlePlayerJoined",
            "actionSequence": [
                {
                    "type": "property",
                    "target": "StatusLabel",
                    "changes": {
                        "text": "P2 ist da! Start..."
                    }
                },
                {
                    "type": "wait",
                    "duration": 1000
                },
                {
                    "type": "action",
                    "name": "NavigateToNextGame"
                }
            ]
        }
    ],
    "variables": [
        {
            "name": "nextGame",
            "defaultValue": ""
        },
        {
            "name": "roomCode",
            "defaultValue": "----"
        }
    ]
}