{
    "meta": {
        "name": "Pong Demo",
        "version": "1.0.0",
        "author": "Game Builder"
    },
    "stage": {
        "grid": {
            "cols": 64,
            "rows": 40,
            "cellSize": 20,
            "snapToGrid": true,
            "visible": false,
            "backgroundColor": "#1a1a2e"
        }
    },
    "objects": [
        {
            "className": "TPanel",
            "id": "center-line",
            "name": "CenterLine",
            "x": 31.5,
            "y": 0,
            "width": 0.2,
            "height": 40,
            "style": {
                "backgroundColor": "#444466",
                "borderWidth": 0
            }
        },
        {
            "className": "TSprite",
            "id": "paddle-left",
            "name": "PaddleLeft",
            "x": 1,
            "y": 18,
            "width": 1,
            "height": 4,
            "velocityX": 0,
            "velocityY": 0,
            "collisionEnabled": true,
            "collisionGroup": "paddle",
            "shape": "rect",
            "spriteColor": "#4fc3f7",
            "style": {
                "backgroundColor": "#4fc3f7",
                "borderColor": "#0288d1",
                "borderWidth": 2
            },
            "Tasks": {
                "onRemoteMoveStart": "HandleRemoteMoveStart",
                "onSyncState": "HandleSyncState",
                "onRemoteMoveStop": "HandleRemoteMoveStop"
            }
        },
        {
            "className": "TSprite",
            "id": "paddle-right",
            "name": "PaddleRight",
            "x": 62,
            "y": 18,
            "width": 1,
            "height": 4,
            "velocityX": 0,
            "velocityY": 0,
            "collisionEnabled": true,
            "collisionGroup": "paddle",
            "shape": "rect",
            "spriteColor": "#ff8a65",
            "style": {
                "backgroundColor": "#ff8a65",
                "borderColor": "#e64a19",
                "borderWidth": 2
            },
            "Tasks": {
                "onRemoteMoveStart": "HandleRemoteMoveStart",
                "onSyncState": "HandleSyncState",
                "onRemoteMoveStop": "HandleRemoteMoveStop"
            }
        },
        {
            "className": "TSprite",
            "id": "ball",
            "name": "Ball",
            "x": 31,
            "y": 19,
            "width": 1,
            "height": 1,
            "velocityX": 0,
            "velocityY": 0,
            "collisionEnabled": true,
            "collisionGroup": "ball",
            "shape": "circle",
            "spriteColor": "#ffffff",
            "style": {
                "backgroundColor": "#ffffff",
                "borderColor": "#cccccc",
                "borderWidth": 0
            },
            "Tasks": {
                "onBoundaryHit": "HandleBoundaryHit",
                "onSyncState": "HandleSyncState",
                "onCollision": "BallBounce"
            }
        },
        {
            "className": "TLabel",
            "id": "score-left",
            "name": "ScoreLeft",
            "x": 18,
            "y": 3,
            "width": 4,
            "height": 2,
            "text": "0",
            "style": {
                "backgroundColor": "transparent",
                "borderWidth": 0,
                "color": "#4fc3f7"
            },
            "fontSize": 32,
            "alignment": "center",
            "Tasks": {
                "onSyncState": "HandleSyncState"
            }
        },
        {
            "className": "TLabel",
            "id": "score-right",
            "name": "ScoreRight",
            "x": 42,
            "y": 3,
            "width": 4,
            "height": 2,
            "text": "0",
            "style": {
                "backgroundColor": "transparent",
                "borderWidth": 0,
                "color": "#ff8a65"
            },
            "fontSize": 32,
            "alignment": "center",
            "Tasks": {
                "onSyncState": "HandleSyncState"
            }
        },
        {
            "className": "TGameHeader",
            "id": "game-header",
            "name": "GameHeader",
            "x": 0,
            "y": 0,
            "width": 64,
            "height": 2,
            "align": "TOP",
            "title": "🏓 PONG",
            "titleAlign": "CENTER",
            "fontSize": 24,
            "fontWeight": "bold",
            "textColor": "#ffffff",
            "style": {
                "backgroundColor": "#0f3460",
                "borderWidth": 0,
                "borderColor": "transparent"
            }
        },
        {
            "className": "TLabel",
            "id": "controls-info",
            "name": "ControlsInfo",
            "x": 1,
            "y": 37,
            "width": 62,
            "height": 2,
            "text": "Player 1: W/S  |  Player 2: ↑/↓",
            "style": {
                "backgroundColor": "transparent",
                "borderWidth": 0,
                "color": "#555577"
            },
            "fontSize": 12,
            "alignment": "center"
        },
        {
            "className": "TGameLoop",
            "id": "pong-gameloop",
            "name": "PongGameLoop",
            "x": 0,
            "y": 0,
            "width": 3,
            "height": 1,
            "targetFPS": 60,
            "boundsWidth": 64,
            "boundsHeight": 40,
            "boundsOffsetTop": 2,
            "bounceTop": true,
            "bounceBottom": true,
            "bounceLeft": false,
            "bounceRight": false,
            "style": {
                "backgroundColor": "#2196f3",
                "borderColor": "#1565c0",
                "borderWidth": 2
            },
            "Tasks": {
                "onStart": "StartBallTask"
            }
        },
        {
            "className": "TInputController",
            "id": "pong-input",
            "name": "PongInput",
            "x": 0,
            "y": 1,
            "width": 3,
            "height": 1,
            "enabled": true,
            "player1Controls": "wasd",
            "player1Target": "PaddleLeft",
            "player1Speed": 0.3,
            "player2Controls": "arrows",
            "player2Target": "PaddleRight",
            "player2Speed": 0.3,
            "verticalOnly": true,
            "horizontalOnly": false,
            "style": {
                "backgroundColor": "#9c27b0",
                "borderColor": "#6a1b9a",
                "borderWidth": 2
            }
        },
        {
            "className": "TTimer",
            "id": "sync-timer",
            "name": "SyncTimer",
            "x": 0,
            "y": 2,
            "width": 3,
            "height": 1,
            "interval": 100,
            "enabled": true,
            "style": {
                "backgroundColor": "#4caf50",
                "borderColor": "#2e7d32",
                "borderWidth": 2
            },
            "Tasks": {
                "onTimer": "PeriodicSync"
            }
        }
    ],
    "actions": [
        {
            "name": "ResetBallCenter",
            "type": "property",
            "target": "Ball",
            "changes": {
                "x": 15,
                "y": 11,
                "velocityX": 0.15,
                "velocityY": 0.1
            }
        },
        {
            "name": "NegateVelocityX",
            "type": "negate",
            "target": "Ball",
            "changes": {
                "velocityX": true
            }
        },
        {
            "name": "ScoreLeftPoint",
            "type": "increment",
            "target": "ScoreLeft",
            "changes": {
                "text": 1
            }
        },
        {
            "name": "ScoreRightPoint",
            "type": "increment",
            "target": "ScoreRight",
            "changes": {
                "text": 1
            }
        },
        {
            "name": "MoveOpponentUp",
            "type": "property",
            "target": "$eventSource",
            "changes": {
                "velocityY": -0.15
            }
        },
        {
            "name": "MoveOpponentDown",
            "type": "property",
            "target": "$eventSource",
            "changes": {
                "velocityY": 0.15
            }
        },
        {
            "name": "StopOpponent",
            "type": "property",
            "target": "$eventSource",
            "changes": {
                "velocityY": 0
            }
        },
        {
            "name": "SyncBall",
            "type": "send_multiplayer_sync",
            "target": "Ball"
        },
        {
            "name": "SyncPaddleLeft",
            "type": "send_multiplayer_sync",
            "target": "PaddleLeft"
        },
        {
            "name": "SyncPaddleRight",
            "type": "send_multiplayer_sync",
            "target": "PaddleRight"
        },
        {
            "name": "SyncScoreLeft",
            "type": "send_multiplayer_sync",
            "target": "ScoreLeft"
        },
        {
            "name": "SyncScoreRight",
            "type": "send_multiplayer_sync",
            "target": "ScoreRight"
        },
        {
            "name": "ApplySmoothSync",
            "type": "smooth_sync",
            "target": "$eventSource"
        },
        {
            "name": "PushBallLeft",
            "type": "increment",
            "target": "Ball",
            "changes": {
                "x": -0.5
            }
        },
        {
            "name": "EnsureVelocityRight",
            "type": "property",
            "target": "Ball",
            "changes": {
                "velocityX": 0.15
            }
        },
        {
            "name": "EnsureVelocityLeft",
            "type": "property",
            "target": "Ball",
            "changes": {
                "velocityX": -0.15
            }
        }
    ],
    "tasks": [
        {
            "name": "PeriodicSync",
            "actionSequence": [
                {
                    "type": "condition",
                    "name": "IfPlayer1",
                    "condition": {
                        "variable": "isPlayer1",
                        "operator": "==",
                        "value": "1"
                    },
                    "thenTask": "MasterSyncP1"
                },
                {
                    "type": "condition",
                    "name": "IfPlayer2",
                    "condition": {
                        "variable": "isPlayer2",
                        "operator": "==",
                        "value": "1"
                    },
                    "thenTask": "MasterSyncP2"
                }
            ]
        },
        {
            "name": "MasterSyncP1",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "SyncBall"
                },
                {
                    "type": "action",
                    "name": "SyncPaddleLeft"
                },
                {
                    "type": "action",
                    "name": "SyncScoreLeft"
                },
                {
                    "type": "action",
                    "name": "SyncScoreRight"
                }
            ]
        },
        {
            "name": "MasterSyncP2",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "SyncPaddleRight"
                }
            ]
        },
        {
            "name": "HandleSyncState",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ApplySmoothSync"
                }
            ]
        },
        {
            "name": "BallBounce",
            "actionSequence": [
                {
                    "type": "task",
                    "name": "DoBallBounce"
                }
            ]
        },
        {
            "name": "DoBallBounce",
            "actionSequence": [
                {
                    "type": "condition",
                    "name": "HitLeftOfBall",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "left"
                    },
                    "thenAction": "EnsureVelocityRight"
                },
                {
                    "type": "condition",
                    "name": "HitRightOfBall",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "right"
                    },
                    "thenAction": "EnsureVelocityLeft"
                }
            ]
        },
        {
            "name": "HandleBoundaryHit",
            "actionSequence": [
                {
                    "type": "condition",
                    "name": "OnlyIfMaster",
                    "condition": {
                        "variable": "isPlayer1",
                        "operator": "==",
                        "value": "1"
                    },
                    "thenTask": "ProcessBoundaryHit"
                }
            ]
        },
        {
            "name": "ProcessBoundaryHit",
            "actionSequence": [
                {
                    "type": "condition",
                    "name": "LeftWall",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "left"
                    },
                    "thenTask": "ScorePlayer2"
                },
                {
                    "type": "condition",
                    "name": "RightWall",
                    "condition": {
                        "variable": "hitSide",
                        "operator": "==",
                        "value": "right"
                    },
                    "thenTask": "ScorePlayer1"
                }
            ]
        },
        {
            "name": "HandleRemoteMoveStart",
            "actionSequence": [
                {
                    "type": "condition",
                    "name": "CheckMoveUp",
                    "condition": {
                        "variable": "direction",
                        "operator": "==",
                        "value": "up"
                    },
                    "thenAction": "MoveOpponentUp"
                },
                {
                    "type": "condition",
                    "name": "CheckMoveDown",
                    "condition": {
                        "variable": "direction",
                        "operator": "==",
                        "value": "down"
                    },
                    "thenAction": "MoveOpponentDown"
                }
            ]
        },
        {
            "name": "HandleRemoteMoveStop",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "StopOpponent"
                }
            ]
        },
        {
            "name": "ScorePlayer1",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ScoreLeftPoint"
                },
                {
                    "type": "action",
                    "name": "ResetBallCenter"
                },
                {
                    "type": "task",
                    "name": "MasterSyncP1"
                }
            ]
        },
        {
            "name": "ScorePlayer2",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ScoreRightPoint"
                },
                {
                    "type": "action",
                    "name": "ResetBallCenter"
                },
                {
                    "type": "task",
                    "name": "MasterSyncP1"
                }
            ]
        },
        {
            "name": "StartBallTask",
            "actionSequence": [
                {
                    "type": "action",
                    "name": "ResetBallCenter"
                }
            ]
        }
    ],
    "variables": []
}