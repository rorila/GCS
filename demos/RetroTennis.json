{
  "version": "3.19.1",
  "meta": {
    "id": "demo_retro_tennis",
    "name": "Retro Tennis",
    "version": "1.5.0",
    "author": "Game Builder Studio",
    "description": "Vollständige Demo: Paddles steuerbar, Kollisionen laufen."
  },
  "variables": [
    {
      "id": "var_score_p1",
      "name": "ScorePlayer1",
      "type": "integer",
      "initialValue": 0,
      "scope": "global"
    },
    {
      "id": "var_score_p2",
      "name": "ScorePlayer2",
      "type": "integer",
      "initialValue": 0,
      "scope": "global"
    }
  ],
  "stages": [
    {
      "id": "stage_blueprint",
      "name": "Blueprint",
      "type": "blueprint",
      "grid": {
        "cols": 40,
        "rows": 30,
        "cellSize": 20,
        "visible": true,
        "backgroundColor": "#ffffff"
      },
      "objects": [
        {
          "id": "obj_game_loop",
          "name": "GameLoop",
          "className": "TGameLoop",
          "description": "Zentraler Loop-Controller.",
          "x": 2, "y": 2, "width": 3, "height": 1,
          "properties": {
             "targetFPS": 60
          },
          "events": {}
        },
        {
          "id": "obj_input_controller",
          "name": "InputController",
          "className": "TInputController",
          "description": "Zentraler Manager für Tastatur-Eingaben.",
          "x": 6, "y": 2, "width": 3, "height": 1,
          "properties": {},
          "events": {
             "onKeyDown_KeyW": "MoveP1Up",
             "onKeyDown_KeyS": "MoveP1Down",
             "onKeyDown_ArrowUp": "MoveP2Up",
             "onKeyDown_ArrowDown": "MoveP2Down",
             "onKeyUp_KeyW": "StopP1",
             "onKeyUp_KeyS": "StopP1",
             "onKeyUp_ArrowUp": "StopP2",
             "onKeyUp_ArrowDown": "StopP2"
          }
        },
        {
          "id": "obj_game_state",
          "name": "GameState",
          "className": "TGameState",
          "description": "Zustandsmaschine des Spiels (menu, playing).",
          "x": 10, "y": 2, "width": 4, "height": 1,
          "properties": {
             "state": "menu"
          },
          "events": {}
        }
      ],
      "tasks": [
        {
          "name": "MoveP1Up",
          "actionSequence": [ { "type": "action", "name": "SetP1Up" } ]
        },
        {
          "name": "MoveP1Down",
          "actionSequence": [ { "type": "action", "name": "SetP1Down" } ]
        },
        {
          "name": "StopP1",
          "actionSequence": [ { "type": "action", "name": "SetP1Stop" } ]
        },
        {
          "name": "MoveP2Up",
          "actionSequence": [ { "type": "action", "name": "SetP2Up" } ]
        },
        {
          "name": "MoveP2Down",
          "actionSequence": [ { "type": "action", "name": "SetP2Down" } ]
        },
        {
          "name": "StopP2",
          "actionSequence": [ { "type": "action", "name": "SetP2Stop" } ]
        }
      ],
      "actions": [
        {
          "id": "act_p1_up",
          "name": "SetP1Up",
          "type": "property",
          "target": "LeftPaddle",
          "changes": { "velocityY": -0.5 }
        },
        {
          "id": "act_p1_down",
          "name": "SetP1Down",
          "type": "property",
          "target": "LeftPaddle",
          "changes": { "velocityY": 0.5 }
        },
        {
          "id": "act_p1_stop",
          "name": "SetP1Stop",
          "type": "property",
          "target": "LeftPaddle",
          "changes": { "velocityY": 0 }
        },
        {
          "id": "act_p2_up",
          "name": "SetP2Up",
          "type": "property",
          "target": "RightPaddle",
          "changes": { "velocityY": -0.5 }
        },
        {
          "id": "act_p2_down",
          "name": "SetP2Down",
          "type": "property",
          "target": "RightPaddle",
          "changes": { "velocityY": 0.5 }
        },
        {
          "id": "act_p2_stop",
          "name": "SetP2Stop",
          "type": "property",
          "target": "RightPaddle",
          "changes": { "velocityY": 0 }
        }
      ],
      "flowCharts": {}
    },
    {
      "id": "stage_main",
      "name": "Spielfeld",
      "type": "main",
      "gameName": "Retro Tennis",
      "backgroundColor": "#1a1a2e",
      "grid": {
        "cols": 40,
        "rows": 30,
        "cellSize": 20,
        "visible": true,
        "backgroundColor": "#1a1a2e"
      },
      "objects": [
        {
          "id": "obj_start_btn",
          "name": "StartButton",
          "className": "TButton",
          "x": 16,
          "y": 10,
          "width": 8,
          "height": 2,
          "properties": {
            "text": "Start Game",
            "backgroundColor": "#4CAF50",
            "color": "#ffffff",
            "visible": true
          },
          "events": {
            "onClick": "StartGameTask"
          }
        },
        {
          "id": "obj_paddle1",
          "name": "LeftPaddle",
          "className": "TSprite",
          "x": 1,
          "y": 12,
          "width": 1,
          "height": 6,
          "properties": {
            "color": "#00d2ff",
            "collisionEnabled": true
          },
          "events": {}
        },
        {
          "id": "obj_paddle2",
          "name": "RightPaddle",
          "className": "TSprite",
          "x": 38,
          "y": 12,
          "width": 1,
          "height": 6,
          "properties": {
            "color": "#ff0055",
            "collisionEnabled": true
          },
          "events": {}
        },
        {
          "id": "obj_ball",
          "name": "Ball",
          "className": "TSprite",
          "x": 19,
          "y": 14,
          "width": 1,
          "height": 1,
          "properties": {
            "color": "#ffffff",
            "velocityX": 0,
            "velocityY": 0,
            "collisionEnabled": true
          },
          "events": {
            "onBoundaryHit": "CheckWallCollisions",
            "onCollision": "BallHitPaddle"
          }
        }
      ],
      "tasks": [
        {
          "name": "StartGameTask",
          "description": "Wird durch den StartButton getriggert.",
          "actionSequence": [
            { "type": "action", "name": "SetStatePlaying" },
            { "type": "action", "name": "EnablePhysics" },
            { "type": "action", "name": "StartBallX" },
            { "type": "action", "name": "StartBallY" },
            { "type": "action", "name": "HideStartButton" }
          ]
        },

        {
          "name": "CheckWallCollisions",
          "actionSequence": [
            {
              "type": "condition",
              "condition": {
                "leftValue": "${hitSide}",
                "operator": "==",
                "rightValue": "top"
              },
              "thenAction": "BounceY"
            },
            {
              "type": "condition",
              "condition": {
                "leftValue": "${hitSide}",
                "operator": "==",
                "rightValue": "bottom"
              },
              "thenAction": "BounceY"
            }
          ]
        },
        {
          "name": "BallHitPaddle",
          "description": "Wenn der Ball kollidiert (z.B. mit dem Paddle), springt er ab.",
          "actionSequence": [
            { "type": "action", "name": "BounceX" }
          ]
        }
      ],
      "actions": [
        {
          "id": "act_set_state",
          "name": "SetStatePlaying",
          "type": "property",
          "target": "GameState",
          "changes": { "state": "playing" }
        },
        {
          "id": "act_enable_physics",
          "name": "EnablePhysics",
          "type": "property",
          "target": "GameState",
          "changes": { "spritesMoving": true, "collisionsEnabled": true }
        },
        {
          "id": "act_start_box",
          "name": "StartBallX",
          "type": "property",
          "target": "Ball",
          "changes": { "velocityX": 0.3 }
        },
        {
          "id": "act_start_boy",
          "name": "StartBallY",
          "type": "property",
          "target": "Ball",
          "changes": { "velocityY": 0.3 }
        },
        {
          "id": "act_hide_btn",
          "name": "HideStartButton",
          "type": "property",
          "target": "StartButton",
          "changes": { "visible": false }
        },
        {
          "id": "act_bounce_y",
          "name": "BounceY",
          "type": "negate",
          "target": "Ball",
          "changes": { "velocityY": true }
        },
        {
          "id": "act_bounce_x",
          "name": "BounceX",
          "type": "negate",
          "target": "Ball",
          "changes": { "velocityX": true }
        }
      ],
      "flowCharts": {}
    }
  ],
  "tasks": [],
  "actions": [],
  "objects": []
}
