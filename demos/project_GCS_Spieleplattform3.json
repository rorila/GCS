            }
          ]
        },
        {
          "name": "AddEmoji8",
          "actionSequence": [
            {
              "type": "calculate",
              "formula": "currentPIN + '🦇'",
              "resultVariable": "currentPIN"
            }
          ]
        },
        {
          "name": "AddEmoji9",
          "actionSequence": [
            {
              "type": "calculate",
              "formula": "currentPIN + '🦄'",
              "resultVariable": "currentPIN"
            }
          ]
        },
        {
          "name": "ResetPIN",
          "actionSequence": [
            {
              "type": "calculate",
              "formula": "''",
              "resultVariable": "currentPIN"
            }
          ]
        },
        {
          "name": "AttemptLogin",
          "actionSequence": [
            {
              "type": "http",
              "url": "/api/platform/login",
              "method": "POST",
              "body": {
                "authCode": "${currentPIN}"
              },
              "resultVariable": "loginResult"
            },
            {
              "type": "calculate",
              "formula": "loginResult.user.avatar",
              "resultVariable": "currentUserAvatar",
              "visible": "${loginResult && loginResult.success}"
            },
            {
              "type": "navigate_stage",
              "stageId": "stage_role_selection",
              "visible": "${loginResult && loginResult.success && loginResult.user.role !== 'player'}"
            },
            {
              "type": "navigate_stage",
              "stageId": "stage_lobby",
              "visible": "${loginResult && loginResult.success && loginResult.user.role === 'player'}"
            }
          ]
        }
      ]
    },
