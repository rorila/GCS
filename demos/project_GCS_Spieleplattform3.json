        {
          "name": "AddEmoji1",
          "actionSequence": [
            {
              "type": "calculate",
              "formula": "currentPIN + '🚀'",
              "resultVariable": "currentPIN"
            }
          ]
        },
        {
          "name": "AddEmoji2",
          "actionSequence": [
            {
              "type": "calculate",
              "formula": "currentPIN + '⭐'",
              "resultVariable": "currentPIN"
            }
          ]
        },
        {
          "name": "AddEmoji3",
          "actionSequence": [
