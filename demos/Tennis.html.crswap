<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tennis</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        #stage-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        #stage {
            position: relative;
            width: 1280px;
            height: 800px;
            background: #1a1c2c;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            border-radius: 8px;
            overflow: hidden;
            transform-origin: center center;
        }
        .game-object {
            position: absolute;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .game-object.button {
            cursor: pointer;
            user-select: none;
        }
        .game-object.button:hover {
            filter: brightness(1.1);
        }
        .game-object.button:active {
            opacity: 0.9;
        }
    </style>
</head>
<body>
    <div id="stage-container">
        <div id="stage"></div>
    </div>
    
    <script>
    // ═══════════════════════════════════════════════════════════════
    // Embedded Project Data
    // ═══════════════════════════════════════════════════════════════
    const PROJECT = {
  "meta": {
    "name": "Tennis",
    "version": "1.0.0",
    "author": "Antigravity GCS"
  },
  "stage": {
    "grid": {
      "cols": 64,
      "rows": 40,
      "cellSize": 20,
      "snapToGrid": true,
      "visible": false,
      "backgroundColor": "#1a1c2c"
    }
  },
  "input": {
    "player1Controls": "arrows",
    "player1Target": "",
    "player1Speed": 0.2,
    "player2Controls": "wasd",
    "player2Target": "",
    "player2Speed": 0.2
  },
  "objects": [
    {
      "className": "TPanel",
      "id": "tennis-net",
      "name": "TennisNet",
      "x": 31.8,
      "y": 0,
      "width": 0.4,
      "height": 40,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "rgba(255, 255, 255, 0.2)",
        "borderColor": "#999999",
        "borderWidth": 0
      },
      "caption": "TennisNet"
    },
    {
      "className": "TSprite",
      "id": "player-1",
      "name": "Player1",
      "x": 2,
      "y": 18,
      "width": 1,
      "height": 4,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "#5d8aa8",
        "borderColor": "#ffffff",
        "borderWidth": 1
      },
      "velocityX": 0,
      "velocityY": 0,
      "lerpSpeed": 0.1,
      "collisionEnabled": true,
      "collisionGroup": "paddle",
      "shape": "rect",
      "spriteColor": "#5d8aa8"
    },
    {
      "className": "TSprite",
      "id": "player-2",
      "name": "Player2",
      "x": 61,
      "y": 18,
      "width": 1,
      "height": 4,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "#ff7f50",
        "borderColor": "#ffffff",
        "borderWidth": 1
      },
      "velocityX": 0,
      "velocityY": 0,
      "lerpSpeed": 0.1,
      "collisionEnabled": true,
      "collisionGroup": "paddle",
      "shape": "rect",
      "spriteColor": "#ff7f50"
    },
    {
      "className": "TSprite",
      "id": "ball",
      "name": "Ball",
      "Tasks": {
        "onBoundaryHit": "CheckGoal",
        "onCollision": "HandleBounce"
      },
      "x": 31,
      "y": 19,
      "width": 1,
      "height": 1,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "#e9ef1a",
        "borderColor": "#ffffff",
        "borderWidth": 1
      },
      "velocityX": 0.2,
      "velocityY": 0.15,
      "lerpSpeed": 0.1,
      "collisionEnabled": true,
      "collisionGroup": "ball",
      "shape": "circle",
      "spriteColor": "#e9ef1a"
    },
    {
      "className": "TLabel",
      "id": "score-label-1",
      "name": "Score1",
      "x": 20,
      "y": 2,
      "width": 6,
      "height": 3,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "transparent",
        "borderColor": "transparent",
        "borderWidth": 0,
        "color": "#ffffff"
      },
      "text": "0",
      "fontSize": 48,
      "alignment": "center",
      "color": "#ffffff"
    },
    {
      "className": "TLabel",
      "id": "score-label-2",
      "name": "Score2",
      "x": 38,
      "y": 2,
      "width": 6,
      "height": 3,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "transparent",
        "borderColor": "transparent",
        "borderWidth": 0,
        "color": "#ffffff"
      },
      "text": "0",
      "fontSize": 48,
      "alignment": "center",
      "color": "#ffffff"
    },
    {
      "className": "TGameLoop",
      "id": "main-loop",
      "name": "MainLoop",
      "Tasks": {
        "onStart": "ResetBall"
      },
      "x": 0,
      "y": 0,
      "width": 3,
      "height": 1,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "#2196f3",
        "borderColor": "#1565c0",
        "borderWidth": 2,
        "color": "#ffffff"
      },
      "targetFPS": 60,
      "bounceTop": true,
      "bounceBottom": true,
      "bounceLeft": false,
      "bounceRight": false,
      "boundsOffsetTop": 0
    },
    {
      "className": "TInputController",
      "id": "input-ctrl",
      "name": "InputCtrl",
      "x": 3,
      "y": 0,
      "width": 3,
      "height": 1,
      "visible": true,
      "align": "NONE",
      "style": {
        "visible": true,
        "backgroundColor": "#9c27b0",
        "borderColor": "#6a1b9a",
        "borderWidth": 2,
        "color": "#ffffff"
      },
      "enabled": true,
      "player1Controls": "wasd",
      "player1Target": "Player1",
      "player1Speed": 0.4,
      "player2Controls": "arrows",
      "player2Target": "Player2",
      "player2Speed": 0.4,
      "verticalOnly": true,
      "horizontalOnly": false
    }
  ],
  "actions": [
    {
      "name": "ResetBallPos",
      "type": "property",
      "target": "Ball",
      "changes": {
        "x": 31,
        "y": 19,
        "velocityX": 0.2,
        "velocityY": 0.15
      }
    },
    {
      "name": "IncrementScore1",
      "type": "increment",
      "target": "Score1",
      "changes": {
        "text": 1
      }
    },
    {
      "name": "IncrementScore2",
      "type": "increment",
      "target": "Score2",
      "changes": {
        "text": 1
      }
    },
    {
      "name": "SetBallVelocityLeft",
      "type": "property",
      "target": "Ball",
      "changes": {
        "velocityX": -0.22
      }
    },
    {
      "name": "SetBallVelocityRight",
      "type": "property",
      "target": "Ball",
      "changes": {
        "velocityX": 0.22
      }
    },
    {
      "name": "HB_ReadBallY",
      "type": "variable",
      "variableName": "ballY",
      "source": "Ball",
      "sourceProperty": "y"
    },
    {
      "name": "HB_ReadPaddle1Y",
      "type": "variable",
      "variableName": "paddleY",
      "source": "Player1",
      "sourceProperty": "y"
    },
    {
      "name": "HB_ReadPaddle2Y",
      "type": "variable",
      "variableName": "paddleY",
      "source": "Player2",
      "sourceProperty": "y"
    },
    {
      "name": "HB_ApplyVY",
      "type": "property",
      "target": "Ball",
      "changes": {
        "velocityY": "${newVY}"
      }
    }
  ],
  "tasks": [
    {
      "name": "ResetBall",
      "actionSequence": [
        {
          "type": "action",
          "name": "ResetBallPos"
        }
      ]
    },
    {
      "name": "CheckGoal",
      "actionSequence": [
        {
          "type": "condition",
          "name": "GoalRight",
          "condition": {
            "variable": "hitSide",
            "operator": "==",
            "value": "right"
          },
          "thenTask": "ScorePlayer1"
        },
        {
          "type": "condition",
          "name": "GoalLeft",
          "condition": {
            "variable": "hitSide",
            "operator": "==",
            "value": "left"
          },
          "thenTask": "ScorePlayer2"
        }
      ]
    },
    {
      "name": "ScorePlayer1",
      "actionSequence": [
        {
          "type": "action",
          "name": "IncrementScore1"
        },
        {
          "type": "task",
          "name": "ResetBall"
        }
      ]
    },
    {
      "name": "ScorePlayer2",
      "actionSequence": [
        {
          "type": "action",
          "name": "IncrementScore2"
        },
        {
          "type": "task",
          "name": "ResetBall"
        }
      ]
    },
    {
      "name": "HandleBounce",
      "actionSequence": [
        {
          "type": "condition",
          "name": "HitPlayer2",
          "condition": {
            "variable": "hitSide",
            "operator": "==",
            "value": "right"
          },
          "body": [
            {
              "type": "action",
              "name": "HB_ReadBallY"
            },
            {
              "type": "action",
              "name": "HB_ReadPaddle2Y"
            },
            {
              "type": "calculate",
              "name": "HB_CalcDiff",
              "resultVariable": "hitDiff",
              "calcSteps": [
                {
                  "operandType": "variable",
                  "variable": "ballY"
                },
                {
                  "operator": "-",
                  "operandType": "variable",
                  "variable": "paddleY"
                },
                {
                  "operator": "-",
                  "operandType": "constant",
                  "constant": 1.5
                }
              ]
            },
            {
              "type": "calculate",
              "name": "HB_CalcVY",
              "resultVariable": "newVY",
              "calcSteps": [
                {
                  "operandType": "variable",
                  "variable": "hitDiff"
                },
                {
                  "operator": "*",
                  "operatorSymbol": "*",
                  "operandType": "constant",
                  "constant": 0.1
                }
              ]
            },
            {
              "type": "action",
              "name": "HB_ApplyVY"
            },
            {
              "type": "action",
              "name": "SetBallVelocityLeft"
            }
          ]
        },
        {
          "type": "condition",
          "name": "HitPlayer1",
          "condition": {
            "variable": "hitSide",
            "operator": "==",
            "value": "left"
          },
          "body": [
            {
              "type": "action",
              "name": "HB_ReadBallY"
            },
            {
              "type": "action",
              "name": "HB_ReadPaddle1Y"
            },
            {
              "type": "calculate",
              "name": "HB_CalcDiff",
              "resultVariable": "hitDiff",
              "calcSteps": [
                {
                  "operandType": "variable",
                  "variable": "ballY"
                },
                {
                  "operator": "-",
                  "operandType": "variable",
                  "variable": "paddleY"
                },
                {
                  "operator": "-",
                  "operandType": "constant",
                  "constant": 1.5
                }
              ]
            },
            {
              "type": "calculate",
              "name": "HB_CalcVY",
              "resultVariable": "newVY",
              "calcSteps": [
                {
                  "operandType": "variable",
                  "variable": "hitDiff"
                },
                {
                  "operator": "*",
                  "operandType": "constant",
                  "constant": 0.1
                }
              ]
            },
            {
              "type": "action",
              "name": "HB_ApplyVY"
            },
            {
              "type": "action",
              "name": "SetBallVelocityRight"
            }
          ]
        }
      ]
    }
  ],
  "variables": []
};

    // ═══════════════════════════════════════════════════════════════
    // Responsive Scaling Configuration
    // ═══════════════════════════════════════════════════════════════
    const BASE_WIDTH = 1280;
    const BASE_HEIGHT = 800;
    const MIN_WIDTH = 1024;
    const MIN_HEIGHT = 600;
    const STAGE_WIDTH = 1280;
    const STAGE_HEIGHT = 800;

    // ═══════════════════════════════════════════════════════════════
    // Minimal Runtime Player with GameLoop, Sprites, Input Support
    // ═══════════════════════════════════════════════════════════════
    class GamePlayer {
        constructor() {
            this.stageContainer = document.getElementById('stage-container');
            this.stage = document.getElementById('stage');
            this.objects = [];
            this.cellSize = PROJECT.stage.grid.cellSize;
            this.scale = 1;
            this.gameLoop = null;
            this.inputControllers = [];
            this.sprites = [];
            this.animationFrameId = null;
            this.lastTime = 0;
            this.keysPressed = {};
            this.init();
        }

        init() {
            // Hydrate objects from JSON
            PROJECT.objects.forEach(objData => {
                const obj = {...objData};
                this.objects.push(obj);
                
                // Track GameLoop
                if (obj.className === 'TGameLoop') {
                    this.gameLoop = obj;
                }
                // Track InputControllers
                if (obj.className === 'TInputController') {
                    this.inputControllers.push(obj);
                }
                // Track Sprites
                if (obj.className === 'TSprite') {
                    this.sprites.push(obj);
                }
            });
            
            // Setup responsive scaling
            this.updateScale();
            window.addEventListener('resize', () => this.updateScale());
            
            // Setup keyboard input
            this.setupKeyboard();
            
            // Initial render
            this.render();
            
            // Start game loop if found
            if (this.gameLoop) {
                console.log('Starting GameLoop:', this.gameLoop.name);
                this.startGameLoop();
            }
            
            console.log('Game started:', PROJECT.meta.name);
        }

        setupKeyboard() {
            window.addEventListener('keydown', (e) => {
                this.keysPressed[e.key] = true;
            });
            window.addEventListener('keyup', (e) => {
                this.keysPressed[e.key] = false;
            });
        }

        startGameLoop() {
            const bounds = {
                width: PROJECT.stage.grid.cols,
                height: PROJECT.stage.grid.rows
            };
            this.lastTime = performance.now();
            
            // Trigger onStart event for the GameLoop
            if (this.gameLoop && this.gameLoop.Tasks && this.gameLoop.Tasks.onStart) {
                this.handleGameLoopEvent(this.gameLoop.id, 'onStart', {});
            }
            
            const loop = () => {
                const now = performance.now();
                const deltaTime = (now - this.lastTime) / 1000;
                this.lastTime = now;
                
                // Update input controllers
                this.updateInput();
                
                // Update sprites
                this.sprites.forEach(sprite => {
                    sprite.x += (sprite.velocityX || 0) * deltaTime * 60;
                    sprite.y += (sprite.velocityY || 0) * deltaTime * 60;
                });
                
                // Check collisions
                this.checkCollisions();
                
                // Check boundaries
                this.checkBoundaries(bounds);
                
                // Render
                this.render();
                
                this.animationFrameId = requestAnimationFrame(loop);
            };
            
            this.animationFrameId = requestAnimationFrame(loop);
        }

        updateInput() {
            this.inputControllers.forEach(ic => {
                if (!ic.enabled) return;
                
                const p1Target = this.objects.find(o => o.name === ic.player1Target);
                const p2Target = this.objects.find(o => o.name === ic.player2Target);
                const p1Speed = ic.player1Speed || 0.2;
                const p2Speed = ic.player2Speed || 0.2;
                const verticalOnly = ic.verticalOnly;
                const topBound = this.gameLoop?.boundsOffsetTop || 0;
                const bounds = {
                    height: this.gameLoop?.boundsHeight || PROJECT.stage.grid.rows
                };
                
                // Player 1 - WASD
                if (ic.player1Controls === 'wasd' && p1Target) {
                    if (this.keysPressed['w'] || this.keysPressed['W']) {
                        p1Target.y = Math.max(topBound, p1Target.y - p1Speed);
                    }
                    if (this.keysPressed['s'] || this.keysPressed['S']) {
                        p1Target.y = Math.min(bounds.height - p1Target.height, p1Target.y + p1Speed);
                    }
                    if (!verticalOnly) {
                        if (this.keysPressed['a'] || this.keysPressed['A']) p1Target.x -= p1Speed;
                        if (this.keysPressed['d'] || this.keysPressed['D']) p1Target.x += p1Speed;
                    }
                }
                
                // Player 2 - Arrows
                if (ic.player2Controls === 'arrows' && p2Target) {
                    if (this.keysPressed['ArrowUp']) {
                        p2Target.y = Math.max(topBound, p2Target.y - p2Speed);
                    }
                    if (this.keysPressed['ArrowDown']) {
                        p2Target.y = Math.min(bounds.height - p2Target.height, p2Target.y + p2Speed);
                    }
                    if (!verticalOnly) {
                        if (this.keysPressed['ArrowLeft']) p2Target.x -= p2Speed;
                        if (this.keysPressed['ArrowRight']) p2Target.x += p2Speed;
                    }
                }
            });
        }

        checkCollisions() {
            for (let i = 0; i < this.sprites.length; i++) {
                for (let j = i + 1; j < this.sprites.length; j++) {
                    const a = this.sprites[i];
                    const b = this.sprites[j];
                    if (!a.collisionEnabled || !b.collisionEnabled) continue;
                    
                    // AABB collision
                    if (a.x < b.x + b.width && a.x + a.width > b.x &&
                        a.y < b.y + b.height && a.y + a.height > b.y) {
                        // Collision detected
                        this.handleGameLoopEvent(a.id, 'onCollision', { other: b.name });
                        this.handleGameLoopEvent(b.id, 'onCollision', { other: a.name });
                    }
                }
            }
        }

        checkBoundaries(bounds) {
            if (!this.gameLoop) return;
            
            this.sprites.forEach(sprite => {
                // Left
                if (sprite.x < 0) {
                    if (this.gameLoop.bounceLeft) {
                        sprite.velocityX *= -1;
                        sprite.x = 0;
                    } else {
                        this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'left' });
                    }
                }
                // Right
                if (sprite.x + sprite.width > bounds.width) {
                    if (this.gameLoop.bounceRight) {
                        sprite.velocityX *= -1;
                        sprite.x = bounds.width - sprite.width;
                    } else {
                        this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'right' });
                    }
                }
                // Top (with offset for headers)
                const topBound = this.gameLoop.boundsOffsetTop || 0;
                if (sprite.y < topBound) {
                    if (this.gameLoop.bounceTop) {
                        sprite.velocityY *= -1;
                        sprite.y = topBound;
                    } else {
                        this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'top' });
                    }
                }
                // Bottom
                if (sprite.y + sprite.height > bounds.height) {
                    if (this.gameLoop.bounceBottom) {
                        sprite.velocityY *= -1;
                        sprite.y = bounds.height - sprite.height;
                    } else {
                        this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'bottom' });
                    }
                }
            });
        }

        handleGameLoopEvent(id, eventName, data) {
            const obj = this.objects.find(o => o.id === id);
            if (!obj || !obj.Tasks) return;
            
            const taskName = obj.Tasks[eventName];
            if (!taskName) return;
            
            const vars = {};
            if (PROJECT.variables) {
                PROJECT.variables.forEach(v => {
                    vars[v.name] = v.defaultValue;
                });
            }
            
            // Add event-specific variables
            if (data) {
                if (data.other) vars['otherSprite'] = data.other;
                if (data.side) vars['hitSide'] = data.side;
            }
            
            this.executeTask(taskName, vars, 0);
        }

        updateScale() {
            const windowWidth = window.innerWidth;
            const windowHeight = window.innerHeight;
            const scaleX = windowWidth / STAGE_WIDTH;
            const scaleY = windowHeight / STAGE_HEIGHT;
            this.scale = Math.min(scaleX, scaleY);
            const minScale = Math.min(MIN_WIDTH / BASE_WIDTH, MIN_HEIGHT / BASE_HEIGHT);
            if (this.scale < minScale) this.scale = minScale;
            this.stage.style.transform = 'scale(' + this.scale + ')';
        }

        render() {
            this.stage.innerHTML = '';
            
            this.objects.forEach(obj => {
                // Skip invisible and runtime-only components
                if (obj.style && obj.style.visible === false) return;
                const type = obj.className;
                if (type === 'TGameLoop' || type === 'TInputController') return; // Don't render runtime components
                
                const el = document.createElement('div');
                el.className = 'game-object';
                el.id = obj.id;
                
                // Position & Size
                el.style.left = (obj.x * this.cellSize) + 'px';
                el.style.top = (obj.y * this.cellSize) + 'px';
                el.style.width = (obj.width * this.cellSize) + 'px';
                el.style.height = (obj.height * this.cellSize) + 'px';
                
                // Style
                if (obj.style) {
                    el.style.backgroundColor = obj.style.backgroundColor || '#f0f0f0';
                    el.style.border = (obj.style.borderWidth || 0) + 'px solid ' + (obj.style.borderColor || 'transparent');
                    if (obj.style.color) el.style.color = obj.style.color;
                }
                
                // Type-specific rendering
                if (type === 'TSprite') {
                    // Sprite with optional circle shape
                    el.style.backgroundColor = obj.spriteColor || obj.style?.backgroundColor || '#ff0000';
                    if (obj.shape === 'circle') {
                        el.style.borderRadius = '50%';
                    }
                } else if (type === 'TButton' || type === 'Button') {
                    el.classList.add('button');
                    el.innerText = obj.caption || obj.name;
                    el.style.fontWeight = 'bold';
                    el.onclick = () => this.handleEvent(obj.id, 'onClick');
                } else if (type === 'TPanel' || type === 'Panel') {
                    // Don't show name/caption for panels in run mode
                    el.style.borderRadius = '4px';
                } else if (type === 'TLabel' || type === 'Label') {
                    el.innerText = obj.text || '';
                    el.style.background = 'transparent';
                    el.style.border = 'none';
                    if (obj.fontSize) el.style.fontSize = obj.fontSize + 'px';
                    if (obj.alignment === 'center') el.style.textAlign = 'center';
                } else if (type === 'TEdit') {
                    el.innerHTML = '';
                    const input = document.createElement('input');
                    input.type = 'text';
                    input.value = obj.text || '';
                    input.placeholder = obj.placeholder || '';
                    input.style.cssText = 'width:100%;height:100%;border:none;background:transparent;padding:0 8px;outline:none;color:inherit;';
                    input.oninput = (e) => { obj.text = e.target.value; };
                    el.appendChild(input);
                } else if (type === 'TGameHeader') {
                    el.innerText = obj.title || obj.caption || '';
                    el.style.fontWeight = obj.fontWeight || 'bold';
                    el.style.fontSize = (obj.fontSize || 18) + 'px';
                }
                
                this.stage.appendChild(el);
            });
        }

        handleEvent(id, eventName) {
            const obj = this.objects.find(o => o.id === id);
            if (!obj || !obj.Tasks) return;
            const taskName = obj.Tasks[eventName];
            if (!taskName) return;
            
            const vars = {};
            if (PROJECT.variables) {
                PROJECT.variables.forEach(v => { vars[v.name] = v.defaultValue; });
            }
            this.executeTask(taskName, vars, 0);
            this.render();
        }

        executeTask(taskName, vars, depth) {
            if (depth >= 10) return;
            const task = PROJECT.tasks.find(t => t.name === taskName);
            if (!task) return;

            task.actionSequence.forEach(seqItem => {
                const item = typeof seqItem === 'string' ? { type: 'action', name: seqItem } : seqItem;

                if (item.type === 'condition') {
                    // Evaluate condition
                    if (item.condition) {
                        const varValue = vars[item.condition.variable];
                        const compareValue = item.condition.value;
                        let result = false;
                        switch (item.condition.operator) {
                            case '==': result = String(varValue) === String(compareValue); break;
                            case '!=': result = String(varValue) !== String(compareValue); break;
                            case '>': result = Number(varValue) > Number(compareValue); break;
                            case '<': result = Number(varValue) < Number(compareValue); break;
                            case '>=': result = Number(varValue) >= Number(compareValue); break;
                            case '<=': result = Number(varValue) <= Number(compareValue); break;
                        }
                        if (result && item.thenAction) {
                            this.executeAction(item.thenAction, vars);
                        } else if (!result && item.elseAction) {
                            this.executeAction(item.elseAction, vars);
                        }
                    }
                } else if (item.type === 'task') {
                    this.executeTask(item.name, vars, depth + 1);
                } else {
                    this.executeAction(item.name, vars);
                }
            });
        }

        executeAction(actionName, vars) {
            const action = PROJECT.actions.find(a => a.name === actionName);
            if (!action) return;

            if (action.type === 'variable') {
                const srcObj = this.objects.find(o => o.name === action.source);
                if (srcObj && action.variableName && action.sourceProperty) {
                    vars[action.variableName] = this.getPropertyValue(srcObj, action.sourceProperty);
                }
            } else if (action.type === 'property' && action.changes) {
                Object.keys(action.changes).forEach(prop => {
                    let value = action.changes[prop];
                    if (typeof value === 'string' && value.includes('${')) {
                        value = value.replace(/\$\{(\w+)\}/g, (_, varName) => vars[varName] !== undefined ? vars[varName] : '');
                    }
                    this.applyValue(action.target, prop, value);
                });
            } else if (action.type === 'increment' && action.changes) {
                Object.keys(action.changes).forEach(prop => {
                    const target = this.objects.find(o => o.name === action.target);
                    if (target) {
                        const current = Number(this.getPropertyValue(target, prop)) || 0;
                        const inc = Number(action.changes[prop]) || 0;
                        this.applyValue(action.target, prop, current + inc);
                    }
                });
            } else if (action.type === 'negate' && action.changes) {
                Object.keys(action.changes).forEach(prop => {
                    const target = this.objects.find(o => o.name === action.target);
                    if (target) {
                        const current = Number(this.getPropertyValue(target, prop)) || 0;
                        this.applyValue(action.target, prop, current * -1);
                    }
                });
            }
        }

        getPropertyValue(obj, propPath) {
            const parts = propPath.split('.');
            let current = obj;
            for (const part of parts) {
                if (current == null) return undefined;
                current = current[part];
            }
            return current;
        }

        applyValue(targetName, prop, value) {
            const target = this.objects.find(o => o.name === targetName);
            if (!target) return;
            if (prop.includes('.')) {
                const parts = prop.split('.');
                let current = target;
                for (let i = 0; i < parts.length - 1; i++) {
                    if (!current[parts[i]]) current[parts[i]] = {};
                    current = current[parts[i]];
                }
                current[parts[parts.length - 1]] = value;
            } else {
                target[prop] = value;
            }
        }
    }

    // Start the game when DOM is ready
    document.addEventListener('DOMContentLoaded', () => {
        new GamePlayer();
    });
    </script>
</body>
</html>