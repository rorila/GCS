{
  "$module": "game",
  "description": "Spielspezifische Komponenten (Sprites, Physics)",
  "components": {

    "TSprite": {
      "description": "Bewegbares Spielobjekt mit Physik und Kollisionserkennung",
      "stage": "main",
      "category": "game",
      "properties": {
        "velocityX":        { "type": "number",  "default": 0, "description": "Horizontale Geschwindigkeit" },
        "velocityY":        { "type": "number",  "default": 0, "description": "Vertikale Geschwindigkeit" },
        "lerpSpeed":        { "type": "number",  "default": 0.1, "description": "Interpolationsgeschwindigkeit (0-1)" },
        "collisionEnabled": { "type": "boolean", "default": true, "description": "Kollisionserkennung aktiv" },
        "collisionGroup":   { "type": "string",  "default": "default", "description": "Kollisionsgruppe" },
        "shape":            { "type": "select",  "default": "rect", "options": ["rect", "circle"] },
        "spriteColor":      { "type": "color",   "default": "#ff6b6b" },
        "backgroundImage":  { "type": "string",  "default": "", "description": "Sprite-Bild URL" },
        "objectFit":        { "type": "select",  "default": "contain", "options": ["cover", "contain", "fill", "none"] }
      },
      "methods": [],
      "events": ["onCollision", "onCollisionLeft", "onCollisionRight", "onCollisionTop", "onCollisionBottom", "onBoundaryHit"],
      "example": {
        "className": "TSprite", "name": "Ball", "x": 30, "y": 20, "width": 2, "height": 2,
        "velocityX": 3, "velocityY": 3, "collisionEnabled": true, "collisionGroup": "ball", "shape": "circle",
        "spriteColor": "#ff6b6b", "style": { "backgroundColor": "#ff6b6b", "borderColor": "#333", "borderWidth": 1 }
      }
    },

    "TSpriteTemplate": {
      "description": "Blueprint-Komponente für das Object Pooling dynamischer Sprites (z.B. Projektile). Erzeugt beim Start N Pool-Instanzen.",
      "stage": "blueprint",
      "category": "game",
      "properties": {
        "poolSize":   { "type": "number",  "default": 10, "description": "Anzahl der vorinitialisierten Instanzen" },
        "autoRecycle":{ "type": "boolean", "default": true, "description": "Automatisch älteste Instanz recyceln, wenn Pool voll ist" },
        "lifetime":   { "type": "number",  "default": 0, "description": "Lebensdauer in Millisekunden (0=unendlich)" }
      },
      "methods": [],
      "events": [],
      "example": {
        "className": "TSpriteTemplate", "name": "BulletTemplate", "x": 0, "y": 0, "width": 1, "height": 1,
        "poolSize": 20, "autoRecycle": true, "lifetime": 3000,
        "spriteColor": "#ffff00", "style": { "backgroundColor": "#ffff00" }
      },
      "warnings": [
        "⚠️ TSpriteTemplate ist zur Laufzeit unsichtbar.",
        "⚠️ Nutze die Action 'spawn_object', um eine Instanz zu platzieren."
      ]
    }

  }
}
