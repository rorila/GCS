{
  "$module": "containers",
  "description": "Container-Komponenten (Panels, Gruppen)",
  "components": {

    "TPanel": {
      "description": "Basis-Container mit optionalem Gitter. Kann als Hintergrund oder Gruppierung dienen.",
      "stage": "main",
      "category": "ui",
      "properties": {
        "caption":   { "type": "string",  "default": "", "description": "Optionaler Titel des Panels" },
        "showGrid":  { "type": "boolean", "default": false, "description": "Gitter im Panel anzeigen" },
        "gridColor": { "type": "color",   "default": "#000000", "description": "Farbe der Gitterlinien" },
        "gridStyle": { "type": "select",  "default": "lines", "options": ["lines", "dots"], "description": "Gitter-Stil" }
      },
      "methods": [],
      "events": ["onClick"],
      "example": {
        "className": "TPanel", "name": "MainPanel", "x": 1, "y": 1, "width": 20, "height": 15,
        "style": { "backgroundColor": "#f0f0f0", "borderColor": "#999999", "borderWidth": 1 }
      }
    },

    "TGroupPanel": {
      "description": "Unsichtbarer logischer Container. Children bewegen sich relativ zum GroupPanel. Ideal als Template für ObjectPool.",
      "stage": "main",
      "category": "ui",
      "isContainer": true,
      "properties": {
        "isContainer":  { "type": "boolean", "default": true, "readonly": true, "description": "Markiert als Drop-Target für Drag&Drop" },
        "isHiddenInRun": { "type": "boolean", "default": false, "description": "Als Template verbergen (unsichtbar zur Laufzeit, spawnbar per Action)" }
      },
      "methods": [],
      "events": ["onClick"],
      "example": {
        "className": "TGroupPanel", "name": "InspectorContainer", "x": 1, "y": 1, "width": 17, "height": 16,
        "style": { "backgroundColor": "#18181A", "borderColor": "#232325", "borderWidth": 1, "borderRadius": 6 },
        "children": [
          { "className": "TLabel", "name": "HeaderLabel", "x": 1, "y": 0.5, "width": 6, "height": 1, "text": "Titel" }
        ]
      },
      "warnings": [
        "⚠️ Children haben relative Koordinaten zum GroupPanel, NICHT zur Stage!",
        "⚠️ Children müssen im children-Array verschachtelt sein, NICHT als flache Objekte mit parentId!"
      ]
    }
  }
}
