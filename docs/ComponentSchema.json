{
  "$schema": "GCS Component Schema Registry v1.0",
  "description": "Maschinenlesbare Schema-Definitionen aller GCS-Komponenten. Wird vom AgentController genutzt um Parameter zu validieren und KIs über verfügbare Properties, Methoden und Events zu informieren.",
  "components": {

    "TSprite": {
      "description": "Bewegbares Spielobjekt mit Physik und Kollisionserkennung",
      "stage": "main",
      "category": "game",
      "properties": {
        "velocityX":        { "type": "number",  "default": 0, "description": "Horizontale Geschwindigkeit" },
        "velocityY":        { "type": "number",  "default": 0, "description": "Vertikale Geschwindigkeit" },
        "lerpSpeed":        { "type": "number",  "default": 0.1, "description": "Interpolationsgeschwindigkeit (0-1)" },
        "collisionEnabled": { "type": "boolean", "default": true, "description": "Kollisionserkennung aktiv" },
        "collisionGroup":   { "type": "string",  "default": "default", "description": "Kollisionsgruppe" },
        "shape":            { "type": "select",  "default": "rect", "options": ["rect", "circle"] },
        "spriteColor":      { "type": "color",   "default": "#ff6b6b" },
        "backgroundImage":  { "type": "string",  "default": "", "description": "Sprite-Bild URL" },
        "objectFit":        { "type": "select",  "default": "contain", "options": ["cover", "contain", "fill", "none"] }
      },
      "methods": [],
      "events": ["onCollision", "onCollisionLeft", "onCollisionRight", "onCollisionTop", "onCollisionBottom", "onBoundaryHit"],
      "example": {
        "className": "TSprite", "name": "Ball", "x": 30, "y": 20, "width": 2, "height": 2,
        "velocityX": 3, "velocityY": 3, "collisionEnabled": true, "collisionGroup": "ball", "shape": "circle",
        "spriteColor": "#ff6b6b", "style": { "backgroundColor": "#ff6b6b", "borderColor": "#333", "borderWidth": 1 }
      }
    },

    "TSpriteTemplate": {
      "description": "Blueprint-Komponente für das Object Pooling dynamischer Sprites (z.B. Projektile). Erzeugt beim Start N Pool-Instanzen.",
      "stage": "blueprint",
      "category": "game",
      "properties": {
        "poolSize":   { "type": "number",  "default": 10, "description": "Anzahl der vorinitialisierten Instanzen" },
        "autoRecycle":{ "type": "boolean", "default": true, "description": "Automatisch älteste Instanz recyceln, wenn Pool voll ist" },
        "lifetime":   { "type": "number",  "default": 0, "description": "Lebensdauer in Millisekunden (0=unendlich)" }
      },
      "methods": [],
      "events": [],
      "example": {
        "className": "TSpriteTemplate", "name": "BulletTemplate", "x": 0, "y": 0, "width": 1, "height": 1,
        "poolSize": 20, "autoRecycle": true, "lifetime": 3000,
        "spriteColor": "#ffff00", "style": { "backgroundColor": "#ffff00" }
      },
      "warnings": [
        "⚠️ TSpriteTemplate ist zur Laufzeit unsichtbar.",
        "⚠️ Nutze die Action 'spawn_object', um eine Instanz zu platzieren."
      ]
    },

    "TButton": {
      "description": "Klickbarer Button mit Text und optionalem Icon",
      "stage": "main",
      "category": "ui",
      "properties": {
        "text":    { "type": "string",  "default": "", "description": "Button-Beschriftung (NICHT 'caption'!)" },
        "enabled": { "type": "boolean", "default": true, "description": "Kann geklickt werden" },
        "icon":    { "type": "string",  "default": "", "description": "Icon-URL" }
      },
      "methods": [],
      "events": ["onClick"],
      "example": {
        "className": "TButton", "name": "StartButton", "x": 27, "y": 2, "width": 10, "height": 2,
        "text": "🚀 Start", "style": { "backgroundColor": "#0078d4", "color": "#ffffff", "fontWeight": "bold", "textAlign": "center", "borderRadius": 8 }
      },
      "warnings": ["⚠️ Property heißt 'text', NICHT 'caption'. caption ist nur ein Legacy-Alias."]
    },

    "TLabel": {
      "description": "Textanzeige mit Variable-Binding (z.B. ${Countdown})",
      "stage": "main",
      "category": "ui",
      "properties": {
        "text": { "type": "string", "default": "", "description": "Anzeigetext. Bindings: ${VariablenName}" }
      },
      "methods": [],
      "events": ["onClick"],
      "example": {
        "className": "TLabel", "name": "CountdownLabel", "x": 29, "y": 18, "width": 6, "height": 4,
        "text": "${Countdown}", "style": { "color": "#f7c948", "fontSize": 72, "fontWeight": "bold", "textAlign": "center", "backgroundColor": "transparent" }
      },
      "warnings": ["⚠️ Variable-Bindings: ${VariablenName} — Dollar+Klammern sind Pflicht!"]
    },

    "TTimer": {
      "description": "Wiederholender Timer mit konfigurierbarem Intervall und Max-Intervall",
      "stage": "main",
      "category": "service",
      "isService": true,
      "isHiddenInRun": true,
      "properties": {
        "interval":        { "type": "number",  "default": 1000, "unit": "ms", "description": "Timer-Intervall in Millisekunden" },
        "enabled":         { "type": "boolean", "default": true, "description": "Timer sofort aktiv bei Spielstart" },
        "maxInterval":     { "type": "number",  "default": 0, "description": "Max Intervalle (0=unendlich). Feuert onMaxIntervalReached wenn erreicht" },
        "currentInterval": { "type": "number",  "default": 0, "description": "Aktuelle Anzahl gefeuterter Intervalle (readonly)" }
      },
      "methods": [
        { "name": "timerStart", "description": "Timer starten (via call_method Action)" },
        { "name": "timerStop",  "description": "Timer stoppen" },
        { "name": "reset",      "description": "Intervall-Zähler auf 0 zurücksetzen" }
      ],
      "events": ["onTimer", "onMaxIntervalReached"],
      "example": {
        "className": "TTimer", "name": "CountdownTimer", "x": 10, "y": 2, "width": 6, "height": 3,
        "isVariable": true, "isService": true, "isHiddenInRun": true,
        "interval": 1000, "enabled": false, "maxInterval": 10, "currentInterval": 0,
        "events": { "onTimer": "OnTimerTick", "onMaxIntervalReached": "OnCountdownFinish" }
      },
      "warnings": [
        "⚠️ Methode heißt 'timerStart', NICHT 'start'!",
        "⚠️ Timer mit enabled=false muss über call_method 'timerStart' gestartet werden",
        "⚠️ maxInterval=0 bedeutet: Timer läuft endlos"
      ]
    },

    "TGameLoop": {
      "description": "Konfigurations-Container für den Game-Loop. Pflicht für Spiele mit Sprites!",
      "stage": "blueprint",
      "category": "infrastructure",
      "isService": true,
      "isHiddenInRun": true,
      "required": true,
      "properties": {
        "targetFPS":          { "type": "number", "default": 60, "description": "Ziel-Framerate" },
        "boundsOffsetTop":    { "type": "number", "default": 0, "description": "Oberer Rand-Offset für Spielbereich" },
        "boundsOffsetBottom": { "type": "number", "default": 0, "description": "Unterer Rand-Offset" }
      },
      "methods": [],
      "events": [],
      "example": {
        "className": "TGameLoop", "name": "GameLoop", "x": 2, "y": 2, "width": 3, "height": 1,
        "isService": true, "isHiddenInRun": true, "targetFPS": 60,
        "style": { "backgroundColor": "#2196f3", "borderColor": "#1565c0", "borderWidth": 2, "color": "#ffffff" }
      },
      "warnings": ["⚠️ PFLICHT für Spiele mit bewegten Sprites! Ohne TGameLoop keine Physik."]
    },

    "TGameState": {
      "description": "Zentraler Spielzustand: state, spritesMoving, collisionsEnabled",
      "stage": "blueprint",
      "category": "infrastructure",
      "isService": true,
      "isHiddenInRun": true,
      "required": true,
      "properties": {
        "state":             { "type": "select",  "default": "idle", "options": ["menu", "playing", "paused", "gameover"] },
        "spritesMoving":     { "type": "boolean", "default": false, "description": "Sprites werden vom GameLoop bewegt" },
        "collisionsEnabled": { "type": "boolean", "default": false, "description": "Kollisionserkennung aktiv" }
      },
      "methods": [],
      "events": [],
      "example": {
        "className": "TGameState", "name": "GameState", "x": 6, "y": 2, "width": 4, "height": 1,
        "isVariable": true, "isService": true, "isHiddenInRun": true,
        "state": "idle", "spritesMoving": false, "collisionsEnabled": false,
        "style": { "backgroundColor": "#4caf50", "color": "#ffffff" }
      }
    },

    "TInputController": {
      "description": "Tastatur-Eingabe-Controller. Feuert Events bei Tastendruck/Loslass",
      "stage": "blueprint",
      "category": "infrastructure",
      "isService": true,
      "isHiddenInRun": true,
      "properties": {
        "enabled": { "type": "boolean", "default": true }
      },
      "methods": [],
      "events": [
        "onKeyDown_KeyW", "onKeyDown_KeyS", "onKeyDown_KeyA", "onKeyDown_KeyD",
        "onKeyDown_ArrowUp", "onKeyDown_ArrowDown", "onKeyDown_ArrowLeft", "onKeyDown_ArrowRight",
        "onKeyDown_Space", "onKeyDown_Enter",
        "onKeyUp_KeyW", "onKeyUp_KeyS", "onKeyUp_KeyA", "onKeyUp_KeyD",
        "onKeyUp_ArrowUp", "onKeyUp_ArrowDown", "onKeyUp_ArrowLeft", "onKeyUp_ArrowRight",
        "onKeyUp_Space", "onKeyUp_Enter"
      ],
      "example": {
        "className": "TInputController", "name": "InputController", "x": 11, "y": 2, "width": 3, "height": 1,
        "isService": true, "isHiddenInRun": true, "enabled": true,
        "style": { "backgroundColor": "#9c27b0", "borderColor": "#6a1b9a", "borderWidth": 2, "color": "#ffffff" }
      },
      "warnings": ["⚠️ Event-Format: onKeyDown_{KeyCode} — z.B. onKeyDown_ArrowUp, onKeyDown_KeyW"]
    },

    "TIntegerVariable": {
      "description": "Ganzzahl-Variable (z.B. Score, Countdown)",
      "stage": "main",
      "category": "variable",
      "isVariable": true,
      "isHiddenInRun": true,
      "properties": {
        "type":         { "type": "string",  "default": "integer", "readonly": true },
        "defaultValue": { "type": "number",  "default": 0, "description": "Startwert bei Spielstart" },
        "value":        { "type": "number",  "default": 0, "description": "Aktueller Wert" }
      },
      "methods": [],
      "events": ["onValueChanged"],
      "example": {
        "className": "TIntegerVariable", "name": "Countdown", "x": 2, "y": 4, "width": 6, "height": 2,
        "isVariable": true, "isHiddenInRun": true, "type": "integer", "defaultValue": 10, "value": 10,
        "style": { "backgroundColor": "#d1c4e9", "borderColor": "#9575cd", "borderWidth": 1, "color": "#000000" }
      }
    },

    "TBooleanVariable": {
      "description": "Wahrheitswert-Variable (true/false)",
      "stage": "main",
      "category": "variable",
      "isVariable": true,
      "isHiddenInRun": true,
      "properties": {
        "type":         { "type": "string",  "default": "boolean", "readonly": true },
        "defaultValue": { "type": "boolean", "default": false },
        "value":        { "type": "boolean", "default": false }
      },
      "methods": [],
      "events": ["onValueChanged"],
      "example": {
        "className": "TBooleanVariable", "name": "SpielAktiv", "x": 2, "y": 6, "width": 6, "height": 2,
        "isVariable": true, "isHiddenInRun": true, "type": "boolean", "defaultValue": false, "value": false
      }
    },

    "TStringVariable": {
      "description": "Text-Variable",
      "stage": "main",
      "category": "variable",
      "isVariable": true,
      "isHiddenInRun": true,
      "properties": {
        "type":         { "type": "string", "default": "string", "readonly": true },
        "defaultValue": { "type": "string", "default": "" },
        "value":        { "type": "string", "default": "" }
      },
      "methods": [],
      "events": ["onValueChanged"],
      "example": {
        "className": "TStringVariable", "name": "Spielername", "x": 2, "y": 8, "width": 6, "height": 2,
        "isVariable": true, "isHiddenInRun": true, "type": "string", "defaultValue": "", "value": ""
      }
    },

    "TRandomVariable": {
      "description": "Zufallszahl-Generator. Generiert Werte zwischen min und max",
      "stage": "main",
      "category": "variable",
      "isVariable": true,
      "isHiddenInRun": true,
      "properties": {
        "min":       { "type": "number",  "default": 1, "description": "Minimalwert" },
        "max":       { "type": "number",  "default": 100, "description": "Maximalwert" },
        "isInteger": { "type": "boolean", "default": true, "description": "Nur Ganzzahlen" },
        "value":     { "type": "number",  "default": 0, "readonly": true, "description": "Zuletzt generierter Wert" }
      },
      "methods": [
        { "name": "generate", "description": "Neuen Zufallswert erzeugen (via call_method). Wert steht danach in .value" }
      ],
      "events": ["onGenerated"],
      "example": {
        "className": "TRandomVariable", "name": "Zahl1", "x": 2, "y": 10, "width": 3, "height": 1,
        "isVariable": true, "isHiddenInRun": true, "min": 1, "max": 20, "isInteger": true,
        "style": { "backgroundColor": "#607d8b", "borderColor": "#455a64", "borderWidth": 2 }
      },
      "warnings": ["⚠️ Methode heißt 'generate' (via call_method Action). Wert danach in ${VariablenName} verfügbar"]
    },

    "TEdit": {
      "description": "Eingabefeld für Text",
      "stage": "main",
      "category": "ui",
      "properties": {
        "text":        { "type": "string",  "default": "", "description": "Eingabetext" },
        "placeholder": { "type": "string",  "default": "", "description": "Platzhalter-Text" }
      },
      "methods": [],
      "events": ["onClick", "onFocus", "onBlur"],
      "example": {
        "className": "TEdit", "name": "NameInput", "x": 10, "y": 5, "width": 10, "height": 2,
        "text": "", "placeholder": "Name eingeben..."
      }
    }
  },

  "actionTypes": {
    "property":       { "description": "Objekt-Property ändern", "params": ["target", "changes"], "example": { "type": "property", "target": "GameState", "changes": { "state": "playing" } } },
    "variable":       { "description": "Variable setzen/lesen", "params": ["source", "sourceProperty", "variableName"] },
    "set_variable":   { "description": "Variable direkt setzen (Alias für variable)", "params": ["source", "sourceProperty", "variableName"] },
    "calculate":      { "description": "Mathematische Berechnung", "params": ["formula", "resultVariable"], "example": { "type": "calculate", "formula": "Countdown - 1", "resultVariable": "Countdown" } },
    "increment":      { "description": "Variable um Wert erhöhen", "params": ["target", "property", "amount"] },
    "negate":         { "description": "Vorzeichen umkehren (×-1)", "params": ["target", "changes"], "example": { "type": "negate", "target": "Ball", "changes": { "velocityX": 1 } } },
    "call_method":    { "description": "Methode auf Objekt aufrufen", "params": ["target", "method"], "example": { "type": "call_method", "target": "CountdownTimer", "method": "timerStart" } },
    "animate":        { "description": "CSS-Animation auslösen", "params": ["target", "animation"] },
    "navigate":       { "description": "Browser-Navigation", "params": ["url"] },
    "navigate_stage": { "description": "Stage wechseln", "params": ["stageId"] },
    "broadcast":      { "description": "Event broadcast (Multiplayer)", "params": ["event", "data"] },
    "http":           { "description": "HTTP-Request ausführen", "params": ["url", "method", "body"] },
    "data_action":    { "description": "Datenbank-Operation", "params": ["resource", "operation", "data"] },
    "service":        { "description": "Service aufrufen", "params": ["service", "method", "args"] }
  },

  "baseProperties": {
    "description": "Diese Properties erben ALLE Komponenten von TWindow",
    "properties": {
      "x":      { "type": "number", "description": "X-Position (Grid-Einheiten)" },
      "y":      { "type": "number", "description": "Y-Position (Grid-Einheiten)" },
      "width":  { "type": "number", "description": "Breite (Grid-Einheiten)" },
      "height": { "type": "number", "description": "Höhe (Grid-Einheiten)" },
      "zIndex": { "type": "number", "default": 0 },
      "visible":{ "type": "boolean", "default": true },
      "text":   { "type": "string", "default": "" },
      "align":  { "type": "select", "default": "NONE", "options": ["NONE", "TOP", "BOTTOM", "LEFT", "RIGHT", "CLIENT"] },
      "style":  {
        "type": "object",
        "properties": {
          "backgroundColor": { "type": "color", "default": "transparent" },
          "borderColor":     { "type": "color", "default": "transparent" },
          "borderWidth":     { "type": "number", "default": 0 },
          "borderRadius":    { "type": "number", "default": 0 },
          "color":           { "type": "color", "description": "Textfarbe" },
          "fontSize":        { "type": "number" },
          "fontFamily":      { "type": "string" },
          "fontWeight":      { "type": "string" },
          "fontStyle":       { "type": "string" },
          "textAlign":       { "type": "select", "options": ["left", "center", "right"] },
          "opacity":         { "type": "number", "min": 0, "max": 1 }
        }
      }
    },
    "baseEvents": ["onClick", "onFocus", "onBlur", "onDragStart", "onDragEnd", "onDrop"]
  },

  "variableTypes": {
    "description": "Alle verfügbaren Variablen-Typen im GCS",
    "types": ["integer", "real", "string", "boolean", "timer", "random", "list", "object", "object_list", "threshold", "trigger", "range", "keystore", "any", "json"]
  },

  "semantik": {
    "description": "Die 7 Schritte zum Aufbau eines GCS-Projekts",
    "steps": [
      "1. ZIEL: Was soll das Spiel/die App können? (1 Satz)",
      "2. OBJEKTE: Was brauche ich auf dem Bildschirm? (TSprite, TButton, TLabel, ...)",
      "3. VARIABLEN: Welcher Zustand muss verfolgt werden? (TIntegerVariable, TRandomVariable, ...)",
      "4. ACTIONS: Was kann passieren? (property, call_method, calculate, negate, ...)",
      "5. TASKS: In welcher Reihenfolge passiert es? (Action-Sequenzen)",
      "6. EVENTS: Was löst die Abläufe aus? (onClick, onTimer, onCollision, ...)",
      "7. TEST: Funktioniert es? (validate())"
    ],
    "rules": [
      "Blueprint-Stage: NUR Infrastruktur (TGameLoop, TGameState, TInputController)",
      "Main-Stage: Spielobjekte, Variablen, Tasks, Actions",
      "KEINE Inline-Actions: Immer addAction() verwenden, nie JSON direkt schreiben",
      "Property heißt 'text', NICHT 'caption' (Legacy-Alias existiert)",
      "Timer-Methoden: timerStart, timerStop, reset (NICHT: start, stop)",
      "Variable-Bindings: ${VariablenName} mit Dollar+Klammern",
      "TRandomVariable.generate() erzeugt neuen Wert, danach in .value verfügbar"
    ]
  }
}
