          "name": "getHitSide"
        },
        {
          "type": "condition",
          "condition": {
            "variable": "hitSide",
            "value": "left"
          },
          "body": [
            {
              "type": "task",
              "name": "RightPlayerScores"
            }
          ],
          "elseBody": [
            {
              "type": "condition",
              "condition": {
                "variable": "hitSide",
                "value": "right"
              },
              "body": [
                {
                  "type": "task",
                  "name": "LeftPlayerScores"
                }
              ],
              "elseBody": [
                {
                  "type": "condition",
                  "condition": {
                    "variable": "hitSide",
                    "value": "top"
                  },
                  "body": [
                    {
                      "type": "action",
                      "name": "ChangeY_DirectionToDown"
                    }
                  ],
                  "elseBody": [
                    {
                      "type": "condition",
                      "condition": {
                        "variable": "hitSide",
                        "value": "bottom"
                      },
                      "body": [
                        {
                          "type": "action",
                          "name": "ChangeY_DirectionToUp"
                        }
                      ],
                      "elseBody": []
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "description": "Handles collision with walls: bounces off top/bottom, or triggers scoring if hits left/right.",
