    },
    {
      "type": "variable",
      "source": "other",
      "sourceProperty": "height",
      "variableName": "paddleH",
      "name": "Get Paddle H",
      "details": "paddleH := other.height",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "variable",
      "source": "self",
      "sourceProperty": "y",
      "variableName": "ballY",
      "name": "Get Ball Y",
      "details": "ballY := self.y",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "variable",
      "source": "self",
      "sourceProperty": "height",
      "variableName": "ballH",
      "name": "Get Ball H",
      "details": "ballH := self.height",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "paddleHalfH",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "paddleH"
        },
        {
          "operator": "/",
          "constant": 2
        }
      ],
      "name": "Calc Paddle Half",
      "details": "paddleHalfH := (Berechnung)",
      "formula": "paddleH / 2",
      "description": "Calculates half the height of the paddle for collision math.",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "ballHalfH",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "ballH"
        },
        {
          "operator": "/",
          "constant": 2
        }
      ],
      "name": "Calc Ball Half",
      "details": "ballHalfH := (Berechnung)",
      "formula": "ballH / 2",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "paddleCenterY",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "paddleY"
        },
        {
          "operator": "+",
          "operandType": "variable",
          "variable": "paddleHalfH"
        }
      ],
      "name": "Paddle Center Y",
      "details": "paddleCenterY := (Berechnung)",
      "formula": "paddleY + paddleHalfH",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "ballCenterY",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "ballY"
        },
        {
          "operator": "+",
          "operandType": "variable",
          "variable": "ballHalfH"
        }
      ],
      "name": "Ball Center Y",
      "details": "ballCenterY := (Berechnung)",
      "formula": "ballY + ballHalfH",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "diffY",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "ballCenterY"
        },
        {
          "operator": "-",
          "operandType": "variable",
          "variable": "paddleCenterY"
        }
      ],
      "name": "Calc Diff Y",
      "details": "diffY := (Berechnung)",
      "formula": "ballCenterY - paddleCenterY",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "factor",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "diffY"
        },
        {
          "operator": "/",
          "operandType": "variable",
          "variable": "paddleHalfH"
        }
      ],
      "name": "Calc Factor",
      "details": "factor := (Berechnung)",
      "formula": "diffY / paddleHalfH",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "calculate",
      "resultVariable": "newVY",
      "calcSteps": [
        {
          "operandType": "variable",
          "variable": "factor"
        },
        {
          "operator": "*",
          "constant": 0.5
        }
      ],
      "name": "Calc New VY",
      "details": "newVY := (Berechnung)",
      "formula": "factor * 0.5",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "property",
      "target": "self",
      "changes": {
        "velocityY": "${newVY}"
      },
      "name": "Set Velocity Y",
      "details": "self.velocityY := ${newVY}",
      "showDetails": false,
      "hostOnly": true
    },
    {
      "type": "negate",
      "target": "self",
      "changes": {
        "velocityX": 1
      },
      "name": "Negate Velocity X",
      "details": "(negate)",
      "showDetails": false,
      "hostOnly": true
    },
