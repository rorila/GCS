{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "game-builder",
  "version": "0.1.0",
  "identifier": "com.gamebuilder.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Game Builder Offline Editor",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "maximized": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' asset:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com asset:; font-src 'self' https://fonts.gstatic.com data: asset:; img-src 'self' data: blob: asset:; connect-src 'self' ws: wss: http://localhost:*;"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
