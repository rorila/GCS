# GCS Game Builder - Umgebungsvariablen
# ------------------------------------

# Log-Level für den Logger (DEBUG, INFO, WARN, ERROR, NONE)
VITE_LOG_LEVEL=DEBUG

# Spezifische Log-Level pro Klasse/Präfix (Überschreibt globalen Wert)
# Format: VITE_LOG_LEVEL_<Präfix>=<LEVEL>
VITE_LOG_LEVEL_StageRenderer=DEBUG
VITE_LOG_LEVEL_TaskExecutor=DEBUG

# Weitere globale Konstanten
VITE_APP_TITLE=GCS Game Builder
