{
    "name": "game-server",
    "version": "1.0.0",
    "description": "Multiplayer game server with WebSocket event relay",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
    },
    "dependencies": {
        "ws": "^8.16.0",
        "express": "^4.18.2",
        "cors": "^2.8.5"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/ws": "^8.5.10",
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}