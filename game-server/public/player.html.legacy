<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Player</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html,
        body {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
        }

        #loading {
            text-align: center;
        }

        #loading .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(255, 255, 255, 0.2);
            border-top-color: #4fc3f7;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        #error {
            display: none;
            text-align: center;
            padding: 40px;
            background: rgba(255, 0, 0, 0.2);
            border-radius: 8px;
        }

        #error h2 {
            color: #ff5252;
            margin-bottom: 10px;
        }

        #stage-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        #stage {
            position: relative;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            border-radius: 8px;
            overflow: hidden;
            transform-origin: center center;
        }

        .game-object {
            position: absolute;
            display: flex;
            justify-content: center;
            align-items: center;
            pointer-events: auto !important;
            /* FORCE ENABLE */
            z-index: 10;
        }

        .game-object.button {
            cursor: pointer;
            user-select: none;
        }

        .game-object.button:hover {
            filter: brightness(1.1);
        }

        .game-object.button:active {
            opacity: 0.9;
        }

        /* Back to lobby button */
        #back-btn {
            position: fixed;
            top: 10px;
            left: 10px;
            background: rgba(0, 0, 0, 0.5);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            z-index: 1000;
        }

        .back-btn:hover {
            background: rgba(255, 255, 255, 0.2);
        }
    </style>
</head>

<body>
    <div id="loading">
        <div class="spinner"></div>
        <p>Laden...</p>
    </div>

    <div id="error">
        <h2>Fehler</h2>
        <p id="error-msg"></p>
        <br>
        <button onclick="location.href='/'">Zur Lobby</button>
    </div>

    <button id="back-btn" style="display:none" onclick="location.href='/'">← Lobby</button>

    <div id="stage-container" style="display:none">
        <div id="stage"></div>
    </div>

    <script>
        // ═══════════════════════════════════════════════════════════════
        // Dynamic Game Player with Multiplayer Support
        // ═══════════════════════════════════════════════════════════════

        console.log(">>> BUILD VERSION: DEBUG-003 <<<");

        let PROJECT = null;
        let gamePlayer = null;
        // The MultiplayerManager is stored on window to ensure it persists across switchGame SPA transitions.
        window.multiplayerManager = null;
        let multiplayerManager = null; // Local reference to sync with window

        async function loadGame() {
            const params = new URLSearchParams(window.location.search);
            const gameName = params.get('game');
            const mode = params.get('mode');

            if (!gameName) {
                showError('Kein Spiel angegeben. Verwende ?game=pong.json');
                return;
            }

            // Initial Load
            if (mode === 'multi') {
                document.getElementById('loading').style.display = 'none';
                document.getElementById('stage-container').style.display = 'flex';
                document.getElementById('back-btn').style.display = 'block';

                // Initial Player Number
                // Multiplayer mode - show lobby first
                // LEGACY: The lobby is now JSON driven (demos/lobby.json)
                // So we actually just init the manager and switch to the game/lobby
                window.multiplayerManager = new MultiplayerManager(gameName);
                multiplayerManager = window.multiplayerManager;

                // If the requested game is lobby.json, we just load it. 
                // If it is regular pong, we might need a distinct flow?
                // For now, assume we just start the game (which might be lobby.json)
                await switchGame(gameName, true);
            } else {
                // Single player mode - start immediately
                await switchGame(gameName, false);
            }
        }


        async function switchGame(gameName, isMultiplayer = false) {
            console.log(`[SwitchGame] Switching to ${gameName} (Multi: ${isMultiplayer})`);
            try {
                // cleanup old game
                if (gamePlayer) {
                    console.log('[SwitchGame] Stopping previous game...');
                    gamePlayer.stop();
                    document.getElementById('stage').innerHTML = ''; // Clear DOM
                }

                console.log(`[SwitchGame] Fetching /games/${gameName}...`);
                const response = await fetch('/games/' + gameName);
                if (!response.ok) {
                    throw new Error(`Spiel nicht gefunden: ${gameName}`);
                }
                PROJECT = await response.json();
                console.log(`[SwitchGame] Loaded JSON: ${PROJECT.meta?.name}`);
                document.title = PROJECT.meta?.name || 'Game Player';

                document.getElementById('loading').style.display = 'none';
                document.getElementById('stage-container').style.display = 'flex';
                document.getElementById('back-btn').style.display = 'block';

                // Initial Player Number
                let pNum = 1;
                const activeManager = window.multiplayerManager || multiplayerManager;

                if (activeManager) {
                    pNum = activeManager.playerNumber;
                    console.log(`[SwitchGame] Handing over active MP Manager (Player ${pNum})`);
                    window.multiplayerManager = activeManager;
                    multiplayerManager = activeManager;
                } else {
                    console.log('[SwitchGame] No active MP Manager found to hand over.');
                }

                gamePlayer = new GamePlayer(isMultiplayer, pNum, activeManager);
                console.log('[SwitchGame] GamePlayer initialized.');

            } catch (err) {
                console.error('[SwitchGame] Error:', err);
                showError(err.message);
            }
        }

        function showError(msg) {
            document.getElementById('loading').style.display = 'none';
            document.getElementById('error').style.display = 'block';
            document.getElementById('error-msg').innerText = msg;
        }

        function startMultiplayerGame(playerNumber) {
            // This is called by legacy lobby logic AND connection logic
            // We now just switch to the requested game (which was loaded in constructor params originally)
            // But wait, creating MPManager stores the gameName.

            if (multiplayerManager && multiplayerManager.gameName) {
                switchGame(multiplayerManager.gameName, true);
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // MultiplayerManager - Handles WebSocket connection and room logic
        // ═══════════════════════════════════════════════════════════════
        class MultiplayerManager {
            constructor(gameName) {
                this.gameName = gameName;
                this.ws = null;
                this.roomCode = null;
                this.playerNumber = 0;
                this.isConnected = false;
                this.onRemoteState = null;
                this.onRemoteInput = null;
                this.msgQueue = []; // Queue for messages before connection
                this.gameStartMsg = null; // Buffer for game_start event
                this.onGameStartCallback = null;

                this.connect();
                // this.setupUI(); // REMOVED: Legacy UI
            }

            connect() {
                const wsUrl = `ws://${window.location.host}`;
                console.log('[MP] Connecting to', wsUrl);
                this.ws = new WebSocket(wsUrl);

                this.ws.onopen = () => {
                    console.log('[MP] Connected');
                    this.isConnected = true;
                    // Flush queue
                    while (this.msgQueue.length > 0) {
                        const msg = this.msgQueue.shift();
                        this.send(msg);
                    }
                };

                this.ws.onclose = () => {
                    console.log('[MP] Disconnected');
                    this.isConnected = false;
                };

                this.ws.onerror = (err) => {
                    console.error('[MP] Error:', err);
                };

                this.ws.onmessage = (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        this.handleMessage(msg);
                    } catch (e) {
                        console.error('[MP] Invalid message:', e);
                    }
                };
            }

            // setupUI() REMOVED

            createRoom(gameName) {
                this.gameStartMsg = null; // Clear old start signal
                // Use specific game name if provided, otherwise default to current (lobby)
                const finalGameName = gameName || this.gameName;
                this.send({ type: 'create_room', gameName: finalGameName });
            }

            joinRoom(code) {
                this.gameStartMsg = null; // Clear old start signal
                this.send({ type: 'join_room', roomCode: code });
            }

            ready() {
                console.log('[MP] Sending ready');
                this.send({ type: 'ready' });
            }

            set onGameStart(callback) {
                this.onGameStartCallback = callback;
                if (callback && this.gameStartMsg) {
                    console.log('[MP] Delivering buffered game_start to new handler');
                    // Use setTimeout to ensure the new GamePlayer is fully initialized before execution
                    setTimeout(() => {
                        if (this.onGameStartCallback === callback) {
                            callback(this.gameStartMsg);
                        }
                    }, 100);
                }
            }

            get onGameStart() {
                return this.onGameStartCallback;
            }

            send(msg) {
                if (this.ws && this.ws.readyState === WebSocket.OPEN) {
                    this.ws.send(JSON.stringify(msg));
                } else {
                    console.log('[MP] Queueing message (not connected yet):', msg.type);
                    this.msgQueue.push(msg);
                }
            }

            sendStateSync(objectId, state) {
                this.send({
                    type: 'state_sync',
                    objectId: objectId,
                    x: state.x,
                    y: state.y,
                    vx: state.vx, // Protocol expects vx
                    vy: state.vy, // Protocol expects vy
                    text: state.text
                });
            }

            sendInput(key, action) {
                console.log('[MP] Sending input:', key, action);
                this.send({
                    type: 'input',
                    key: key,
                    action: action
                });
            }

            handleMessage(msg) {
                console.log('[MP] Received:', msg.type, msg);

                switch (msg.type) {
                    case 'room_created':
                        this.roomCode = msg.roomCode;
                        this.playerNumber = 1;
                        if (this.onRoomCreated) this.onRoomCreated(msg);
                        break;

                    case 'room_joined':
                        this.roomCode = msg.roomCode;
                        this.playerNumber = msg.playerNumber;
                        if (this.onRoomJoined) this.onRoomJoined(msg);

                        // Both players ready to start
                        this.ready();
                        break;

                    case 'player_joined':
                        // Player 2 joined, both ready
                        if (this.onPlayerJoined) this.onPlayerJoined(msg);
                        this.ready();
                        break;

                    case 'game_start':
                        console.log('[MP] Game starting! Player:', this.playerNumber, 'Seed:', msg.seed);
                        this.gameStartMsg = msg;
                        if (this.onGameStartCallback) this.onGameStartCallback(msg);
                        break;

                    case 'remote_state':
                        if (this.onRemoteState) {
                            this.onRemoteState(msg);
                        }
                        break;

                    case 'remote_input':
                        if (this.onRemoteInput) {
                            this.onRemoteInput(msg);
                        }
                        break;

                    case 'remote_input':
                        if (this.onRemoteInput) {
                            this.onRemoteInput(msg);
                        }
                        break;

                    case 'player_left':
                        console.log('[MP] Player left');
                        alert('Gegner hat das Spiel verlassen!');
                        window.location.href = '/';
                        break;

                    case 'error':
                        alert('Fehler: ' + msg.message);
                        break;
                }
            }
        }

        // ═══════════════════════════════════════════════════════════════
        // GamePlayer - Runtime for JSON games
        // ═══════════════════════════════════════════════════════════════
        class GamePlayer {
            constructor(isMultiplayer = false, playerNumber = 1, mpManager = null) {
                this.stageContainer = document.getElementById('stage-container');
                this.stage = document.getElementById('stage');
                this.objects = [];
                this.cellSize = PROJECT.stage.grid.cellSize;
                this.scale = 1;
                this.gameLoop = null;
                this.inputControllers = [];
                this.sprites = [];
                this.timers = [];
                this.animationFrameId = null;
                this.lastTime = 0;
                this.keysPressed = {};
                // Collision cooldown tracking
                this.collisionCooldowns = new Map();
                this.COLLISION_COOLDOWN_MS = 200;
                // Boundary hit tracking (prevent repeated events)
                this.boundaryHitCooldowns = new Map();
                this.BOUNDARY_COOLDOWN_MS = 500;

                // Multiplayer
                this.isMultiplayer = isMultiplayer;
                this.playerNumber = playerNumber;
                this.mpManager = mpManager;
                this.globalVars = {}; // Persistent variable storage across tasks
                this.syncCounter = 0;

                this.init();
                if (this.mpManager) {
                    this.setupMultiplayerHooks();
                }
            }

            setupMultiplayerHooks() {
                if (!this.mpManager) return;
                console.log('[GamePlayer] Setting up multiplayer hooks');
                this.mpManager.onRemoteState = (msg) => this.handleRemoteState(msg);
                this.mpManager.onRemoteInput = (msg) => this.handleRemoteInput(msg);
                this.mpManager.onRoomCreated = (msg) => {
                    if (this.gameLoop) this.handleGameLoopEvent(this.gameLoop.id, 'onRoomCreated', { roomCode: msg.roomCode });
                };
                this.mpManager.onRoomJoined = (msg) => {
                    if (this.gameLoop) {
                        this.handleGameLoopEvent(this.gameLoop.id, 'onRoomJoined', {
                            roomCode: msg.roomCode,
                            playerNumber: msg.playerNumber,
                            nextGame: msg.gameName
                        });
                    }
                };
                this.mpManager.onPlayerJoined = (msg) => {
                    if (this.gameLoop) this.handleGameLoopEvent(this.gameLoop.id, 'onPlayerJoined', {});
                };
                this.mpManager.onGameStart = (msg) => {
                    console.log('[GamePlayer] Handling onGameStart event', msg);
                    if (this.gameLoop) {
                        console.log('[GamePlayer] Triggering onGameStart on GameLoop:', this.gameLoop.name);
                        this.handleGameLoopEvent(this.gameLoop.id, 'onGameStart', { yourPlayer: msg.yourPlayer, seed: msg.seed });
                    } else {
                        console.warn('[GamePlayer] Received onGameStart but no GameLoop found!');
                    }
                };
            }

            stop() {
                if (this.animationFrameId) {
                    cancelAnimationFrame(this.animationFrameId);
                }
                this.timers.forEach(t => {
                    if (t._intervalId) clearInterval(t._intervalId);
                });
            }

            ensureMultiplayer() {
                if (!this.mpManager) {
                    // Check global first
                    if (window.multiplayerManager) {
                        console.log('Re-using global MultiplayerManager for this game instance');
                        this.mpManager = window.multiplayerManager;
                    } else {
                        console.log('Lazy initializing new MultiplayerManager...');
                        const gameName = PROJECT.meta.name || 'generic-lobby';
                        this.mpManager = new MultiplayerManager(gameName);
                        window.multiplayerManager = this.mpManager; // Sync back to global
                    }
                    this.setupMultiplayerHooks();
                    this.isMultiplayer = true;
                }
            }

            init() {
                // Setup stage size
                const stageWidth = PROJECT.stage.grid.cols * this.cellSize;
                const stageHeight = PROJECT.stage.grid.rows * this.cellSize;
                this.stage.style.width = stageWidth + 'px';
                this.stage.style.height = stageHeight + 'px';
                this.stage.style.background = PROJECT.stage.grid.backgroundColor || '#ffffff';

                // Hydrate objects from JSON
                PROJECT.objects.forEach(objData => {
                    const obj = { ...objData };
                    this.objects.push(obj);

                    // Track GameLoop
                    if (obj.className === 'TGameLoop') {
                        this.gameLoop = obj;
                    }
                    // Track InputControllers
                    if (obj.className === 'TInputController') {
                        this.inputControllers.push(obj);
                    }
                    // Track Sprites
                    if (obj.className === 'TSprite') {
                        this.sprites.push(obj);
                    }
                    // Track Timers
                    if (obj.className === 'TTimer') {
                        this.timers.push(obj);
                    }
                });

                // Setup responsive scaling
                this.updateScale();
                window.addEventListener('resize', () => this.updateScale());

                // DIAGNOSTIC: Global click listener
                document.addEventListener('click', (e) => {
                    const x = e.clientX;
                    const y = e.clientY;
                    const el = document.elementFromPoint(x, y);
                    console.log(`[Global] Click at (${x},${y}) hit: <${el.tagName} id="${el.id}" class="${el.className}">`);
                    console.log('       -> InnerHTML preview:', el.innerText ? el.innerText.substring(0, 20) : '...');
                    // alert("Global Click!"); // Uncomment if desperate
                });

                // DIAGNOSTIC: Debug Button
                const btn = document.createElement('button');
                btn.innerText = "TEST CLICK";
                btn.style.cssText = "position:fixed; top:50px; left:50px; z-index:9999; padding:20px; background:red; color:white; font-weight:bold;";
                btn.onclick = () => {
                    alert("Debug Button Works! Problem is likely in the Stage/Game Objects.");
                    console.log("[Debug] Button clicked.");
                };
                document.body.appendChild(btn);

                // Setup keyboard input
                this.setupKeyboard();

                // Initial render
                this.render();

                // Start game loop if found
                if (this.gameLoop) {
                    console.log('Starting GameLoop:', this.gameLoop.name);
                    this.startGameLoop();
                }

                // Start timers
                this.startTimers();

                this.setupDebugOverlay();

                console.log('Game started:', PROJECT.meta.name);
            }

            setupDebugOverlay() {
                let dbg = document.getElementById('debug-overlay');
                if (!dbg) {
                    dbg = document.createElement('div');
                    dbg.id = 'debug-overlay';
                    dbg.style.cssText = "position:fixed; bottom:10px; right:10px; background:rgba(0,0,0,0.7); color:#0f0; padding:10px; font-family:monospace; font-size:12px; z-index:9999; border-radius:4px; pointer-events:none;";
                    document.body.appendChild(dbg);
                }
                const mode = this.isMultiplayer ? `MULTI (P${this.playerNumber})` : 'SINGLE';
                dbg.innerText = `Mode: ${mode} | Game: ${PROJECT.meta.name}`;
            }

            setupKeyboard() {
                window.addEventListener('keydown', (e) => {
                    if (this.keysPressed[e.key]) return; // ignore repeats
                    this.keysPressed[e.key] = true;

                    if (this.isMultiplayer && this.mpManager) {
                        this.mpManager.sendInput(e.key, 'down');
                    }
                });
                window.addEventListener('keyup', (e) => {
                    this.keysPressed[e.key] = false;

                    if (this.isMultiplayer && this.mpManager) {
                        this.mpManager.sendInput(e.key, 'up');
                    }
                });
            }

            startGameLoop() {
                const bounds = {
                    width: this.gameLoop.boundsWidth || PROJECT.stage.grid.cols,
                    height: this.gameLoop.boundsHeight || PROJECT.stage.grid.rows
                };
                this.lastTime = performance.now();

                const loop = () => {
                    const now = performance.now();
                    const deltaTime = (now - this.lastTime) / 1000;
                    this.lastTime = now;

                    // Update input controllers
                    this.updateInput();

                    // Update sprites
                    this.sprites.forEach(sprite => {
                        sprite.x += (sprite.velocityX || 0) * deltaTime * 60;
                        sprite.y += (sprite.velocityY || 0) * deltaTime * 60;
                    });

                    // Check collisions
                    this.checkCollisions();

                    // Check boundaries
                    this.checkBoundaries(bounds);

                    // Render
                    this.render();

                    this.animationFrameId = requestAnimationFrame(loop);
                };

                this.animationFrameId = requestAnimationFrame(loop);
            }

            startTimers() {
                this.timers.forEach(timer => {
                    if (timer.enabled !== false) {
                        timer._intervalId = setInterval(() => {
                            this.handleGameLoopEvent(timer.id, 'onTimer', {});
                        }, timer.interval || 1000);
                    }
                });
            }

            updateInput() {
                this.inputControllers.forEach(ic => {
                    if (!ic.enabled) return;

                    const p1Target = this.objects.find(o => o.name === ic.player1Target);
                    const p2Target = this.objects.find(o => o.name === ic.player2Target);
                    const p1Speed = ic.player1Speed || 0.2;
                    const p2Speed = ic.player2Speed || 0.2;
                    const verticalOnly = ic.verticalOnly;
                    const topBound = this.gameLoop?.boundsOffsetTop || 0;
                    const bounds = {
                        height: this.gameLoop?.boundsHeight || PROJECT.stage.grid.rows
                    };

                    // Note: We intentionally run this for ALL players.
                    // Local keys come from keyboard events.
                    // Remote keys come from handleRemoteInput -> keysPressed.

                    // Player 1 - WASD
                    if (ic.player1Controls === 'wasd' && p1Target) {
                        if (this.keysPressed['w'] || this.keysPressed['W']) {
                            p1Target.y = Math.max(topBound, p1Target.y - p1Speed);
                        }
                        if (this.keysPressed['s'] || this.keysPressed['S']) {
                            p1Target.y = Math.min(bounds.height - p1Target.height, p1Target.y + p1Speed);
                        }
                        if (!verticalOnly) {
                            if (this.keysPressed['a'] || this.keysPressed['A']) p1Target.x -= p1Speed;
                            if (this.keysPressed['d'] || this.keysPressed['D']) p1Target.x += p1Speed;
                        }
                    }

                    // Player 2 - Arrows
                    if (ic.player2Controls === 'arrows' && p2Target) {
                        if (this.keysPressed['ArrowUp']) {
                            p2Target.y = Math.max(topBound, p2Target.y - p2Speed);
                        }
                        if (this.keysPressed['ArrowDown']) {
                            p2Target.y = Math.min(bounds.height - p2Target.height, p2Target.y + p2Speed);
                        }
                        if (!verticalOnly) {
                            if (this.keysPressed['ArrowLeft']) p2Target.x -= p2Speed;
                            if (this.keysPressed['ArrowRight']) p2Target.x += p2Speed;
                        }
                    }
                });
            }

            checkCollisions() {
                const now = performance.now();

                for (let i = 0; i < this.sprites.length; i++) {
                    for (let j = i + 1; j < this.sprites.length; j++) {
                        const a = this.sprites[i];
                        const b = this.sprites[j];
                        if (!a.collisionEnabled || !b.collisionEnabled) continue;

                        // AABB collision check
                        const colliding = a.x < b.x + b.width && a.x + a.width > b.x &&
                            a.y < b.y + b.height && a.y + a.height > b.y;

                        if (colliding) {
                            // Check cooldown to prevent repeated events
                            const pairKey = `${a.id}_${b.id}`;
                            const lastCollision = this.collisionCooldowns.get(pairKey) || 0;

                            if (now - lastCollision < this.COLLISION_COOLDOWN_MS) {
                                continue; // Still in cooldown, skip
                            }

                            // Update cooldown
                            this.collisionCooldowns.set(pairKey, now);

                            // Calculate hit side for proper bounce direction
                            const dx = (a.x + a.width / 2) - (b.x + b.width / 2);
                            const dy = (a.y + a.height / 2) - (b.y + b.height / 2);
                            const combinedHalfWidths = (a.width + b.width) / 2;
                            const combinedHalfHeights = (a.height + b.height) / 2;
                            const overlapX = combinedHalfWidths - Math.abs(dx);
                            const overlapY = combinedHalfHeights - Math.abs(dy);

                            let hitSideA, hitSideB;
                            if (overlapX < overlapY) {
                                hitSideA = dx > 0 ? 'left' : 'right';
                                hitSideB = dx > 0 ? 'right' : 'left';
                            } else {
                                hitSideA = dy > 0 ? 'top' : 'bottom';
                                hitSideB = dy > 0 ? 'bottom' : 'top';
                            }

                            console.log(`[Collision] ${a.name} hit ${b.name} on ${hitSideA}`);

                            // Trigger collision events with hitSide
                            this.handleGameLoopEvent(a.id, 'onCollision', { other: b.name, hitSide: hitSideA });
                            this.handleGameLoopEvent(b.id, 'onCollision', { other: a.name, hitSide: hitSideB });
                        }
                    }
                }
            }

            checkBoundaries(bounds) {
                if (!this.gameLoop) return;
                const now = performance.now();

                this.sprites.forEach(sprite => {
                    // Left
                    if (sprite.x < 0) {
                        if (this.gameLoop.bounceLeft) {
                            sprite.velocityX *= -1;
                            sprite.x = 0;
                        } else {
                            const key = `${sprite.id}_left`;
                            const last = this.boundaryHitCooldowns.get(key) || 0;
                            if (now - last >= this.BOUNDARY_COOLDOWN_MS) {
                                this.boundaryHitCooldowns.set(key, now);
                                this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'left' });
                            }
                        }
                    }
                    // Right
                    if (sprite.x + sprite.width > bounds.width) {
                        if (this.gameLoop.bounceRight) {
                            sprite.velocityX *= -1;
                            sprite.x = bounds.width - sprite.width;
                        } else {
                            const key = `${sprite.id}_right`;
                            const last = this.boundaryHitCooldowns.get(key) || 0;
                            if (now - last >= this.BOUNDARY_COOLDOWN_MS) {
                                this.boundaryHitCooldowns.set(key, now);
                                this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'right' });
                            }
                        }
                    }
                    // Top (with offset for headers)
                    const topBound = this.gameLoop.boundsOffsetTop || 0;
                    if (sprite.y < topBound) {
                        if (this.gameLoop.bounceTop) {
                            sprite.velocityY *= -1;
                            sprite.y = topBound;
                        } else {
                            const key = `${sprite.id}_top`;
                            const last = this.boundaryHitCooldowns.get(key) || 0;
                            if (now - last >= this.BOUNDARY_COOLDOWN_MS) {
                                this.boundaryHitCooldowns.set(key, now);
                                this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'top' });
                            }
                        }
                    }
                    // Bottom
                    if (sprite.y + sprite.height > bounds.height) {
                        if (this.gameLoop.bounceBottom) {
                            sprite.velocityY *= -1;
                            sprite.y = bounds.height - sprite.height;
                        } else {
                            const key = `${sprite.id}_bottom`;
                            const last = this.boundaryHitCooldowns.get(key) || 0;
                            if (now - last >= this.BOUNDARY_COOLDOWN_MS) {
                                this.boundaryHitCooldowns.set(key, now);
                                this.handleGameLoopEvent(sprite.id, 'onBoundaryHit', { side: 'bottom' });
                            }
                        }
                    }
                });
            }

            handleGameLoopEvent(id, eventName, data) {
                const obj = this.objects.find(o => o.id === id);
                if (!obj || !obj.Tasks) return;

                const taskName = obj.Tasks[eventName];
                if (!taskName) return;

                console.log(`[Event] ${obj.name}: ${eventName}`, data);

                const vars = {};
                if (PROJECT.variables) {
                    PROJECT.variables.forEach(v => {
                        vars[v.name] = v.defaultValue;
                    });
                }

                // Set player variables based on multiplayer state
                if (this.isMultiplayer) {
                    vars['isPlayer1'] = this.playerNumber === 1 ? 1 : 0;
                    vars['isPlayer2'] = this.playerNumber === 2 ? 1 : 0;
                } else {
                    // Single player = player 1 (master)
                    vars['isPlayer1'] = 1;
                    vars['isPlayer2'] = 0;
                }

                // Add event-specific variables
                if (data) {
                    if (data.other) vars['otherSprite'] = data.other;
                    if (data.roomCode) vars['roomCode'] = data.roomCode;
                    if (data.nextGame) vars['nextGame'] = data.nextGame;
                    if (data.seed) vars['seed'] = data.seed;
                    if (data.yourPlayer) vars['yourPlayer'] = data.yourPlayer;
                    // hitSide can come from collision or boundary events
                    if (data.hitSide) vars['hitSide'] = data.hitSide;
                    if (data.side) vars['hitSide'] = data.side;
                }

                // Apply persistent global state (CRITICAL: was missing here)
                Object.assign(vars, this.globalVars);

                this.executeTask(taskName, vars, 0);
            }

            // Handle remote state sync from other player
            handleRemoteState(msg) {
                const target = this.objects.find(o => o.name === msg.target || o.id === msg.objectId); // Support both formats
                if (!target) return;

                // console.log(`[Remote] Syncing ${target.name}:`, msg);

                // If object has onSyncState task, use it (Hybrid approach)
                if (target.Tasks && target.Tasks['onSyncState']) {
                    const taskName = target.Tasks['onSyncState'];
                    const vars = {
                        targetX: msg.x,
                        targetY: msg.y,
                        targetVX: msg.vx,
                        targetVY: msg.vy,
                        targetText: msg.text,
                        syncedObject: target.name
                    };
                    this.executeTask(taskName, vars, 0);
                } else {
                    // Fallback: Apply position/velocity directly
                    if (msg.x !== undefined) target.x = msg.x;
                    if (msg.y !== undefined) target.y = msg.y;
                    if (msg.vx !== undefined) target.velocityX = msg.vx; // Fixed vx key match
                    if (msg.vy !== undefined) target.velocityY = msg.vy; // Fixed vy key match
                    if (msg.text !== undefined) {
                        target.text = msg.text;
                        const el = document.getElementById(target.id);
                        if (el) el.innerText = target.text;
                    }
                }
            }

            // Handle remote input from other player
            handleRemoteInput(msg) {
                console.log('[Remote] Input received:', msg.key, msg.action);
                // Simulate key press for updateInput to pick up
                this.keysPressed[msg.key] = (msg.action === 'down');
            }

            updateScale() {
                const stageWidth = PROJECT.stage.grid.cols * this.cellSize;
                const stageHeight = PROJECT.stage.grid.rows * this.cellSize;
                const windowWidth = window.innerWidth;
                const windowHeight = window.innerHeight;
                const scaleX = windowWidth / stageWidth;
                const scaleY = windowHeight / stageHeight;
                this.scale = Math.min(scaleX, scaleY) * 0.9; // 90% to leave some margin
                this.stage.style.transform = 'scale(' + this.scale + ')';
            }

            render() {
                // this.stage.innerHTML = ''; // NO! Do not wipe DOM every frame.

                // Track existing IDs to handle deletions if needed (optional optimization)
                // const renderedIds = new Set();

                this.objects.forEach(obj => {
                    // Skip invisible and runtime-only components
                    if (obj.visible === false || (obj.style && obj.style.visible === false)) {
                        // If it exists, hide it or remove it
                        const existing = document.getElementById(obj.id);
                        if (existing) existing.style.display = 'none';
                        return;
                    }

                    const type = obj.className;
                    if (type === 'TGameLoop' || type === 'TInputController' || type === 'TTimer' || type === 'TGameServer') return;

                    let el = document.getElementById(obj.id);
                    let isNew = false;

                    if (!el) {
                        isNew = true;
                        el = document.createElement('div');
                        el.className = 'game-object';
                        el.id = obj.id;
                        this.stage.appendChild(el);
                    } else {
                        // Ensure it's visible if it was hidden
                        if (el.style.display === 'none') el.style.display = 'flex';
                    }

                    // Position & Size (Update every frame)
                    el.style.left = (obj.x * this.cellSize) + 'px';
                    el.style.top = (obj.y * this.cellSize) + 'px';
                    el.style.width = (obj.width * this.cellSize) + 'px';
                    el.style.height = (obj.height * this.cellSize) + 'px';

                    // Style (Update every frame to support animations/changes)
                    if (obj.style) {
                        el.style.backgroundColor = obj.style.backgroundColor || '#f0f0f0';
                        el.style.border = (obj.style.borderWidth || 0) + 'px solid ' + (obj.style.borderColor || 'transparent');
                        if (obj.style.color) el.style.color = obj.style.color;
                    }

                    // Type-specific rendering
                    if (type === 'TSprite') {
                        el.style.backgroundColor = obj.spriteColor || obj.style?.backgroundColor || '#ff0000';
                        if (obj.shape === 'circle') {
                            el.style.borderRadius = '50%';
                        }
                    } else if (type === 'TButton' || type === 'Button') {
                        el.classList.add('button');
                        if (isNew || el.innerText !== (obj.caption || obj.name)) {
                            el.innerText = obj.caption || obj.name;
                        }
                        el.style.fontWeight = 'bold';
                        el.onclick = () => this.handleEvent(obj.id, 'onClick');
                    } else if (type === 'TPanel' || type === 'Panel') {
                        el.style.borderRadius = '4px';
                    } else if (type === 'TLabel' || type === 'Label') {
                        if (el.innerText !== (obj.text || '')) el.innerText = obj.text || '';

                        el.style.background = 'transparent';
                        el.style.border = 'none';
                        if (obj.fontSize) el.style.fontSize = obj.fontSize + 'px';
                        if (obj.alignment === 'center') el.style.textAlign = 'center';
                        if (obj.alignment === 'right') el.style.textAlign = 'right';
                    } else if (type === 'TTextInput') {
                        // Only create input once
                        if (isNew) {
                            el.innerHTML = '';
                            const input = document.createElement('input');
                            input.type = 'text';
                            input.id = 'input-' + obj.id;
                            input.placeholder = obj.placeholder || '';
                            if (obj.maxLength) input.maxLength = obj.maxLength;

                            // Default Style
                            input.style.cssText = 'width:100%;height:100%;border:none;background:transparent;padding:0 8px;outline:none;color:inherit;font-family:inherit;font-size:inherit;';
                            if (obj.uppercase) input.style.textTransform = 'uppercase';

                            input.oninput = (e) => {
                                obj.text = e.target.value;
                                if (obj.uppercase) obj.text = obj.text.toUpperCase();
                            };
                            input.onkeydown = (e) => e.stopPropagation();
                            input.onkeyup = (e) => e.stopPropagation();
                            el.appendChild(input);
                        }
                        // Update value if changed programmatically (one-way binding is tricky, assume DOM is truth for input)
                        // If we want complete two-way, we check if active element is this input
                        const input = el.querySelector('input');
                        if (input && document.activeElement !== input) {
                            if (input.value !== (obj.text || '')) input.value = obj.text || '';
                        }

                    } else if (type === 'TGameHeader') {
                        if (el.innerText !== (obj.title || obj.caption || '')) el.innerText = obj.title || obj.caption || '';
                        el.style.fontWeight = obj.fontWeight || 'bold';
                        el.style.fontSize = (obj.fontSize || 18) + 'px';
                    } else if (type === 'TGameCard') {
                        // Only build innerHTML once to preserve listeners
                        if (isNew) {
                            el.style.flexDirection = 'column';
                            el.style.padding = '12px';
                            el.style.borderRadius = '8px';
                            el.innerHTML = `
                            <div style="font-size:16px;font-weight:bold;color:#4fc3f7;text-align:center">${obj.gameName || obj.name}</div>
                            <div style="display:flex;flex-direction:column;gap:4px;margin-top:8px">
                                <button class="card-btn single" style="padding:6px;border:none;border-radius:4px;background:#4caf50;color:#fff;cursor:pointer">▶ Single</button>
                                <button class="card-btn multi" style="padding:6px;border:none;border-radius:4px;background:#2196f3;color:#fff;cursor:pointer;pointer-events:auto!important;position:relative;z-index:999">👥 Multi</button>
                            </div>
                        `;
                            const btnSingle = el.querySelector('.single');
                            const btnMulti = el.querySelector('.multi');

                            btnSingle.onclick = (e) => {
                                console.log('[UI] Clicked Single (Handler)');
                                this.handleEvent(obj.id, 'onSingleClick');
                            };

                            btnMulti.onclick = (e) => {
                                console.log('[UI] Clicked Multi (Handler)');
                                this.handleEvent(obj.id, 'onMultiClick');
                            };

                            console.log('[Render] Attached listeners to Pong Card buttons');
                        }
                    }
                });
            } // End of render()

            handleEvent(objectId, eventType) {
                const obj = this.objects.find(o => o.id === objectId);
                if (!obj) {
                    console.warn(`[Event] Object not found: ${objectId}`);
                    return;
                }

                if (!obj.Tasks || !obj.Tasks[eventType]) {
                    // console.log(`[Event] No task mapped for ${obj.name}.${eventType}`);
                    return;
                }

                const taskName = obj.Tasks[eventType];
                console.log(`[Event] Triggered: ${obj.name}.${eventType}`);
                console.log(`[Event] ${obj.name}.${eventType} -> Task: ${taskName}`);

                // Initialize variables (Merge Global Vars over Defaults)
                const vars = {};
                if (PROJECT.variables) {
                    PROJECT.variables.forEach(v => {
                        // Check URL params for overrides
                        const urlVal = (new URLSearchParams(window.location.search)).get(v.name);
                        vars[v.name] = urlVal !== null ? urlVal : v.defaultValue;
                    });
                }
                // Apply persistent global state
                Object.assign(vars, this.globalVars);

                this.executeTask(taskName, vars, 0);
                this.render();
            }

            executeTask(taskName, vars, depth) {
                if (depth >= 10) return;
                const task = PROJECT.tasks.find(t => t.name === taskName);
                if (!task) {
                    console.warn(`[Task] Task not found: ${taskName}`);
                    return;
                }

                // console.log(`[Task] Executing ${taskName}`);

                task.actionSequence.forEach(seqItem => {
                    const item = typeof seqItem === 'string' ? { type: 'action', name: seqItem } : seqItem;

                    if (item.type === 'condition') {
                        if (item.condition) {
                            const varValue = vars[item.condition.variable];
                            const compareValue = item.condition.value;
                            let result = false;
                            switch (item.condition.operator) {
                                case '==': result = String(varValue) === String(compareValue); break;
                                case '!=': result = String(varValue) !== String(compareValue); break;
                                case '>': result = Number(varValue) > Number(compareValue); break;
                                case '<': result = Number(varValue) < Number(compareValue); break;
                                case '>=': result = Number(varValue) >= Number(compareValue); break;
                                case '<=': result = Number(varValue) <= Number(compareValue); break;
                            }

                            if (result) {
                                if (item.thenAction) {
                                    this.executeAction(item.thenAction, vars);
                                }
                                if (item.thenTask) {
                                    this.executeTask(item.thenTask, vars, depth + 1);
                                }
                            } else {
                                if (item.elseAction) {
                                    this.executeAction(item.elseAction, vars);
                                }
                                if (item.elseTask) {
                                    this.executeTask(item.elseTask, vars, depth + 1);
                                }
                            }
                        }
                    } else if (item.type === 'task') {
                        this.executeTask(item.name, vars, depth + 1);
                    } else if (item.type === 'action') {
                        // Named action reference
                        this.executeAction(item.name, vars);
                    } else {
                        // Inline action definition (property, wait, etc.)
                        this.executeAction(item, vars);
                    }
                });
            }

            executeAction(actionOrName, vars) {
                let action = actionOrName;
                if (typeof actionOrName === 'string') {
                    action = PROJECT.actions.find(a => a.name === actionOrName);
                    if (!action) {
                        console.warn(`[Action] Action not found: ${actionOrName}`);
                        return;
                    }
                }

                if (!action) {
                    console.warn(`[Action] Invalid action object passed`);
                    return;
                }

                console.log(`[Action] Executing ${action.name || 'Inline'} (${action.type})`);

                if (action.type === 'variable') {
                    // This seems to be "read from object to variable"? (unused in Lobby)
                    const srcObj = this.objects.find(o => o.name === action.source);
                    if (srcObj && action.variableName && action.sourceProperty) {
                        vars[action.variableName] = this.getPropertyValue(srcObj, action.sourceProperty);
                        this.globalVars[action.variableName] = vars[action.variableName]; // SYNC TO GLOBAL
                    }
                } else if (action.type === 'set_variable') {
                    // Manually added type to set a variable directly
                    if (action.variable && action.value !== undefined) {
                        vars[action.variable] = action.value;
                        this.globalVars[action.variable] = action.value; // SYNC TO GLOBAL
                        console.log(`[Action] Set variable ${action.variable} = ${action.value} (Global)`);
                    }
                } else if (action.type === 'property' && action.changes) {
                    Object.keys(action.changes).forEach(prop => {
                        let value = action.changes[prop];
                        if (typeof value === 'string' && value.includes('${')) {
                            value = value.replace(/\$\{(\w+)\}/g, (_, varName) => vars[varName] !== undefined ? vars[varName] : '');
                        }
                        this.applyValue(action.target, prop, value);
                    });
                } else if (action.type === 'increment' && action.changes) {
                    Object.keys(action.changes).forEach(prop => {
                        const target = this.objects.find(o => o.name === action.target);
                        if (target) {
                            const current = Number(this.getPropertyValue(target, prop)) || 0;
                            const inc = Number(action.changes[prop]) || 0;
                            this.applyValue(action.target, prop, current + inc);
                        }
                    });
                } else if (action.type === 'negate' && action.changes) {
                    Object.keys(action.changes).forEach(prop => {
                        const target = this.objects.find(o => o.name === action.target);
                        if (target) {
                            const current = Number(this.getPropertyValue(target, prop)) || 0;
                            this.applyValue(action.target, prop, current * -1);
                        }
                    });
                } else if (action.type === 'navigate') {
                    let targetGame = action.target;

                    // Variable Interpolation for Target
                    if (targetGame && targetGame.includes('${')) {
                        console.log(`[Action] Interpolating path: ${targetGame}`);
                        targetGame = targetGame.replace(/\$\{(\w+)\}/g, (_, varName) => vars[varName] !== undefined ? vars[varName] : '');
                        console.log(`[Action] Resolved path: ${targetGame}`);
                    }

                    if (targetGame) {
                        const currentMode = (new URLSearchParams(window.location.search)).get('mode');
                        const targetMode = action.params?.mode || currentMode;

                        console.log(`[Action] Navigating to: ${targetGame} (Mode: ${targetMode})`);

                        if (typeof switchGame === 'function') {
                            const isMulti = targetMode === 'multi';
                            console.log(`[Action] Calling switchGame("${targetGame}", ${isMulti})`);
                            switchGame(targetGame, isMulti);

                            const newUrl = `/player.html?game=${targetGame}&mode=${targetMode || ''}`;
                            window.history.pushState({ path: newUrl }, '', newUrl);
                        } else {
                            console.warn('[Action] switchGame global function not found, falling back to reload');
                            let url = '/player.html?game=' + targetGame;
                            if (targetMode) url += '&mode=' + targetMode;
                            window.location.href = url;
                        }
                    } else {
                        console.warn('[Action] Navigate failed: No targetGame resolved');
                    }
                } else if (action.type === 'create_room') {
                    console.log(`[Action] Executing ${action.name} (create_room)`);
                    this.ensureMultiplayer();
                    // Resolve game name from variables if provided
                    let gameName = action.game;
                    if (gameName && gameName.includes('${')) {
                        gameName = gameName.replace(/\$\{(\w+)\}/g, (_, varName) => vars[varName] !== undefined ? vars[varName] : '');
                    }
                    this.mpManager.createRoom(gameName);
                } else if (action.type === 'join_room') {
                    console.log(`[Action] Executing ${action.name} (join_room)`);
                    this.ensureMultiplayer();

                    const srcObj = this.objects.find(o => o.name === action.source);
                    let code = '';
                    if (srcObj) {
                        code = this.getPropertyValue(srcObj, 'text') || srcObj.text;
                    } else if (action.params && action.params.code) {
                        code = action.params.code;
                    }

                    if (code && code.length >= 4) {
                        this.mpManager.joinRoom(code);
                    } else {
                        console.warn('[Action] Invalid room code');
                    }
                } else if (action.type === 'send_multiplayer_sync') {
                    // Send sync to other player
                    const targetName = action.target;
                    const target = this.objects.find(o => o.name === targetName);

                    if (target && this.mpManager) {
                        const state = {
                            x: target.x,
                            y: target.y,
                            vx: target.velocityX,
                            vy: target.velocityY,
                            text: target.text // Added for score sync
                        };
                        // console.log('[SyncDebug] Sending', targetName, state);
                        this.mpManager.sendStateSync(target.id, state);
                    }
                } else if (action.type === 'smooth_sync') {
                    // Apply sync data (from handleRemoteState)
                    let targetName = action.target;
                    if (targetName === '$eventSource') {
                        targetName = vars.syncedObject;
                    }

                    const target = this.objects.find(o => o.name === targetName);
                    if (target) {
                        // Apply Sync
                        console.log('[SyncDebug] Updating', target.name, vars);
                        // 1. Position (Simulate smoothSync from Editor)
                        if (vars.targetX !== undefined) target.x = Number(vars.targetX);
                        if (vars.targetY !== undefined) target.y = Number(vars.targetY);

                        // 2. Velocity
                        if (vars.targetVX !== undefined) target.velocityX = Number(vars.targetVX);
                        if (vars.targetVY !== undefined) target.velocityY = Number(vars.targetVY);

                        // Apply Text and update DOM immediately (GameLoop ignores text)
                        if (vars.targetText !== undefined) {
                            target.text = vars.targetText;
                            const el = document.getElementById(target.id);
                            if (el) {
                                el.innerText = target.text;
                            }
                        }

                        // Debug Overlay Update
                        const dbg = document.getElementById('debug-overlay');
                        if (dbg) dbg.innerText = `Last Sync: ${target.name} -> X:${target.x?.toFixed(2)} Y:${target.y?.toFixed(2)} VX:${target.velocityX} VY:${target.velocityY}`;
                    }
                } else if (false && action.type === 'smooth_sync') { // DISABLED OLD BLOCK
                    // Apply sync data (from handleRemoteState)
                    const targetName = action.target === '$eventSource' ? (this.objects.find(o => o.name === vars.otherSprite) || this.currentEventSource)?.name : action.target;

                    // Note: player.html doesn't have "currentEventSource" tracking like Editor yet fully. 
                    // But for onSyncState tasks, the target IS the object executing the task.
                    // We can find the object that triggered this flow. Or use a simpler approach:
                    // In handleRemoteState, we call executeTask. The 'vars' contain the target info.
                    // But 'smooth_sync' action usually targets '$eventSource'.

                    // Workaround: In handleRemoteState, we set vars.targetX/Y/Text.
                    // And we are executing a task on the target object.
                    // The 'target' in action definition for 'ApplySmoothSync' is '$eventSource'.
                    // So we need to resolve $eventSource.

                    // Actually, let's just use the values from 'vars' to update the object that triggered this task?
                    // We need to know WHICH object is executing this.
                    // executeTask doesn't pass 'this object'.

                    // FIX: Let's assume the task is running on the object that needs sync.
                    // We need to look at how we called executeTask in handleRemoteState.
                    // We did: this.executeTask(taskName, vars, 0);
                    // use handleGameLoopEvent approach? No, manual executeTask.
                    // We need to pass the context object to executeTask/Action.

                    // Let's modify executeTask to accept a context object?
                    // OR: simpler - assume 'smooth_sync' updates the object found by name if possible, OR if action.target is $eventSource, we rely on 'vars.targetName' (not present)?

                    // In handleRemoteState: 
                    // const target = ...
                    // const vars = { ... }
                    // this.executeTask(..., vars, 0);

                    // We are missing the context of "who is $eventSource".
                    // Let's assume for now we can infer it or just apply to 'target' if we knew it.

                    // BETTER FIX: use 'vars.targetX' etc. along with finding the object.
                    // BUT which object?
                    // The action definition says "target": "$eventSource".

                    // Let's change handleRemoteState to pass the target object name in vars?
                    // vars['syncedObject'] = target.name;

                }
            }

            getPropertyValue(obj, propPath) {
                const parts = propPath.split('.');
                let current = obj;
                for (const part of parts) {
                    if (current == null) return undefined;
                    current = current[part];
                }
                return current;
            }

            applyValue(targetName, prop, value) {
                const target = this.objects.find(o => o.name === targetName);
                if (!target) return;
                if (prop.includes('.')) {
                    const parts = prop.split('.');
                    let current = target;
                    for (let i = 0; i < parts.length - 1; i++) {
                        if (!current[parts[i]]) current[parts[i]] = {};
                        current = current[parts[i]];
                    }
                    current[parts[parts.length - 1]] = value;
                } else {
                    target[prop] = value;
                }
            }
        }

        // Start loading when DOM is ready
        document.addEventListener('DOMContentLoaded', loadGame);
    </script>
</body>

</html>