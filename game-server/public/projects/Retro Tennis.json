        {
          "name": "CheckWallCollisions",
          "actionSequence": [
            {
              "condition": {
                "leftValue": "${hitSide}",
                "operator": "==",
                "rightValue": "top"
              },
              "type": "condition",
              "body": [
                {
                  "name": "BounceY",
                  "type": "action"
                }
              ],
              "elseBody": [
                {
                  "condition": {
                    "leftValue": "${hitSide}",
                    "operator": "==",
                    "rightValue": "bottom"
                  },
                  "type": "condition",
                  "body": [
                    {
                      "name": "BounceY",
                      "type": "action"
                    }
                  ],
                  "elseBody": [
                    {
                      "condition": {
                        "leftValue": "${hitSide}",
                        "rightValue": "left"
                      },
                      "type": "condition",
                      "body": [
                        {
                          "name": "BounceX",
                          "type": "action"
                        }
                      ],
                      "elseBody": [
                        {
                          "condition": {
                            "leftValue": "${hitSide}",
                            "rightValue": "right"
                          },
                          "type": "condition",
                          "body": [
                            {
                              "name": "BounceX",
                              "type": "action"
                            }
                          ],
                          "elseBody": []
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ],
          "params": [],
          "flowLayout": {
            "CheckWallCollisions": {
              "x": 40,
              "y": 40
            },
            "${hitSide} == top": {
              "x": 40,
              "y": 140
            },
            "BounceY": {
              "x": 280,
              "y": 240
            },
            "${hitSide} == bottom": {
              "x": 40,
              "y": 240
            },
            "${hitSide} == left": {
              "x": 40,
              "y": 340
            },
            "BounceX": {
              "x": 280,
              "y": 440
            },
            "${hitSide} == right": {
              "x": 40,
              "y": 440
            }
          }
