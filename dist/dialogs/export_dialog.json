{
    "title": "📚 Export to Library",
    "width": 600,
    "height": 550,
    "modal": true,
    "objects": [
        {
            "className": "TLabel",
            "name": "HintLabel",
            "text": "Kopiere diesen JSON-Code in deine public/library.json Datei:",
            "style": {
                "fontSize": 13,
                "color": "#aaa",
                "marginBottom": 12
            }
        },
        {
            "className": "TMemo",
            "name": "JsonOutput",
            "text": "${dialogData.json}",
            "readOnly": true,
            "style": {
                "height": 380,
                "fontFamily": "monospace",
                "fontSize": 11,
                "backgroundColor": "#1e1e1e",
                "color": "#9cdcfe"
            }
        }
    ],
    "buttons": [
        {
            "caption": "💾 In Library speichern",
            "action": "saveToLibrary",
            "style": {
                "backgroundColor": "#2e7d32",
                "color": "#fff"
            }
        },
        {
            "caption": "Fertig",
            "action": "cancel",
            "style": {
                "backgroundColor": "#0e639c",
                "color": "#fff"
            }
        }
    ]
}