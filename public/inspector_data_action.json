{
    "objects": [
        {
            "name": "NameInput",
            "className": "TEdit",
            "label": "Action Name",
            "text": "${selectedObject.name}",
            "style": {
                "marginBottom": "12px",
                "fontSize": "11px",
                "opacity": "0.6"
            }
        },
        {
            "name": "selectFieldsInput",
            "className": "TDropdown",
            "label": "SELECT (Felder)",
            "selectedValue": "${selectedObject.selectFields}",
            "options": "${availableResourceProperties}",
            "placeholder": "* (Alle Felder)",
            "style": {
                "marginBottom": "4px",
                "borderLeft": "3px solid #ffca28"
            }
        },
        {
            "name": "dataStoreInput",
            "className": "TDropdown",
            "label": "FROM (Data Store)",
            "selectedValue": "${selectedObject.dataStore}",
            "options": "${availableDataStores}",
            "placeholder": "-- Component Store --",
            "style": {
                "marginBottom": "4px",
                "borderLeft": "3px solid #4fc3f7"
            }
        },
        {
            "name": "PropQueryWrapper",
            "className": "TPanel",
            "visible": "${selectedObject.dataStore}",
            "style": {
                "borderLeft": "3px solid #66bb6a",
                "paddingLeft": "8px",
                "marginBottom": "8px"
            },
            "children": [
                {
                    "name": "queryLabel",
                    "className": "TLabel",
                    "text": "WHERE",
                    "style": {
                        "fontSize": "10px",
                        "fontWeight": "bold",
                        "color": "#81c784",
                        "marginBottom": "2px"
                    }
                },
                {
                    "name": "queryPropertyInput",
                    "className": "TDropdown",
                    "label": "Suchfeld",
                    "selectedValue": "${selectedObject.queryProperty}",
                    "options": "${availableResourceProperties}",
                    "placeholder": "-- Ganze Liste --",
                    "style": {
                        "marginBottom": "4px"
                    }
                },
                {
                    "name": "queryValueInput",
                    "className": "TDropdown",
                    "label": "==",
                    "selectedValue": "${selectedObject.queryValue}",
                    "options": "${availableVariablesAsTokens}",
                    "placeholder": "-- Wert/Variable --",
                    "visible": "${selectedObject.queryProperty}"
                }
            ]
        },
        {
            "name": "resultVariableInput",
            "className": "TDropdown",
            "label": "INTO (Ziel-Variable)",
            "selectedValue": "${selectedObject.resultVariable}",
            "options": "${availableVariablesWithScope}",
            "placeholder": "-- Keine --",
            "style": {
                "marginTop": "8px",
                "borderLeft": "3px solid #ec407a"
            }
        },
        {
            "name": "AdvancedPanel",
            "className": "TPanel",
            "label": "Erweitert",
            "style": {
                "marginTop": "12px",
                "borderTop": "1px solid #444",
                "paddingTop": "8px"
            },
            "children": [
                {
                    "name": "urlInput",
                    "className": "TEdit",
                    "label": "Interne Route",
                    "text": "${selectedObject.url}",
                    "enabled": false,
                    "style": {
                        "opacity": "0.5",
                        "fontSize": "10px"
                    }
                },
                {
                    "name": "requestJWTInput",
                    "className": "TCheckbox",
                    "label": "JWT / Login Modus",
                    "checked": "${selectedObject.requestJWT}",
                    "style": {
                        "marginTop": "4px",
                        "color": "#aaa",
                        "fontSize": "11px"
                    }
                }
            ]
        }
    ],
    "footer": [
        {
            "name": "DeleteBtn",
            "className": "TButton",
            "caption": "Löschen",
            "action": "delete",
            "style": {
                "backgroundColor": "#d11a2a",
                "flex": "0 1 auto"
            }
        },
        {
            "name": "CancelBtn",
            "className": "TButton",
            "caption": "Abbrechen",
            "action": "cancel",
            "style": {
                "backgroundColor": "#444",
                "flex": "0 1 auto"
            }
        },
        {
            "name": "SaveBtn",
            "className": "TButton",
            "caption": "Speichern",
            "action": "save",
            "style": {
                "backgroundColor": "#0e639c",
                "flex": "1"
            }
        }
    ]
}