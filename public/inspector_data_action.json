{
    "objects": [
        {
            "name": "NameInput",
            "className": "TEdit",
            "label": "Name",
            "text": "${selectedObject.Name}"
        },
        {
            "name": "dataStoreInput",
            "className": "TDropdown",
            "label": "Data Store (Komponente)",
            "selectedValue": "${selectedObject.dataStore}",
            "options": "${availableDataStores}",
            "placeholder": "-- Component Store --",
            "style": {
                "marginBottom": "4px",
                "borderLeft": "3px solid #4fc3f7"
            }
        },
        {
            "name": "PropQueryWrapper",
            "className": "TPanel",
            "visible": "${selectedObject.dataStore}",
            "children": [
                {
                    "name": "queryPropertyInput",
                    "className": "TDropdown",
                    "label": "Suche in Feld",
                    "selectedValue": "${selectedObject.queryProperty}",
                    "options": "${availableResourceProperties}",
                    "placeholder": "-- Ganze Liste --",
                    "style": {
                        "marginBottom": "4px"
                    }
                },
                {
                    "name": "queryValueInput",
                    "className": "TDropdown",
                    "label": "Suchwert",
                    "selectedValue": "${selectedObject.queryValue}",
                    "options": "${availableVariablesAsTokens}",
                    "placeholder": "-- Wert/Variable --",
                    "visible": "${selectedObject.queryProperty}"
                }
            ]
        },
        {
            "name": "urlInput",
            "className": "TEdit",
            "label": "Route / URL",
            "text": "${selectedObject.url}",
            "enabled": false,
            "style": {
                "opacity": "0.7",
                "backgroundColor": "#222"
            }
        },
        {
            "name": "URLHelpWrapper",
            "className": "TPanel",
            "children": [
                {
                    "name": "URLHelp",
                    "className": "TLabel",
                    "text": "Tipp: Die Route wird automatisch generiert.",
                    "style": {
                        "fontSize": "10px",
                        "color": "#aaa",
                        "fontStyle": "italic",
                        "marginBottom": "4px"
                    }
                }
            ],
            "style": {
                "marginBottom": "8px"
            }
        },
        {
            "name": "methodInput",
            "className": "TDropdown",
            "label": "Methode",
            "selectedValue": "${selectedObject.method}",
            "options": [
                "GET",
                "POST",
                "PUT",
                "DELETE"
            ]
        },
        {
            "name": "resultVariableInput",
            "className": "TDropdown",
            "label": "Ziel-Variable",
            "selectedValue": "${selectedObject.resultVariable}",
            "options": "${availableVariablesWithScope}",
            "placeholder": "-- Keine --"
        },
        {
            "name": "resultPathInput",
            "className": "TDropdown",
            "label": "Daten-Pfad (Selektor)",
            "selectedValue": "${selectedObject.resultPath}",
            "options": "${availableResourceProperties}",
            "placeholder": "z.B. user oder data.item",
            "hint": "Pfad zum Objekt in der Server-Antwort"
        },
        {
            "name": "bodyInput",
            "className": "TMemo",
            "label": "Body (JSON)",
            "text": "${selectedObject.body}",
            "visible": "${selectedObject.method !== 'GET'}",
            "style": {
                "height": "80px",
                "fontFamily": "monospace"
            }
        }
    ],
    "footer": [
        {
            "name": "DeleteBtn",
            "className": "TButton",
            "caption": "Löschen",
            "action": "delete",
            "style": {
                "backgroundColor": "#d11a2a",
                "flex": "0 1 auto"
            }
        },
        {
            "name": "CancelBtn",
            "className": "TButton",
            "caption": "Abbrechen",
            "action": "cancel",
            "style": {
                "backgroundColor": "#444",
                "flex": "0 1 auto"
            }
        },
        {
            "name": "SaveBtn",
            "className": "TButton",
            "caption": "Speichern",
            "action": "save",
            "style": {
                "backgroundColor": "#0e639c",
                "flex": "1"
            }
        }
    ]
}