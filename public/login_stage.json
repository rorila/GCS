    "tasks": [
        {
            "name": "HandleDrop1",
            "actionSequence": [
                {
                    "type": "calculate",
                    "formula": "$eventSource.children[0].text",
                    "resultVariable": "Code1"
                },
                {
                    "type": "property",
                    "target": "Slot1",
                    "changes": {
                        "fillColor": "#2ecc71"
                    }
                }
            ]
        },
        {
            "name": "HandleDrop2",
            "actionSequence": [
                {
                    "type": "calculate",
                    "formula": "$eventSource.children[0].text",
                    "resultVariable": "Code2"
                },
                {
                    "type": "property",
                    "target": "Slot2",
                    "changes": {
                        "fillColor": "#2ecc71"
                    }
                }
            ]
        },
        {
            "name": "HandleDrop3",
            "actionSequence": [
                {
                    "type": "calculate",
                    "formula": "$eventSource.children[0].text",
                    "resultVariable": "Code3"
                },
                {
                    "type": "property",
                    "target": "Slot3",
                    "changes": {
                        "fillColor": "#2ecc71"
                    }
                }
            ]
        },
        {
            "name": "HandleDrop4",
            "actionSequence": [
                {
                    "type": "calculate",
                    "formula": "$eventSource.children[0].text",
                    "resultVariable": "Code4"
                },
                {
                    "type": "property",
                    "target": "Slot4",
                    "changes": {
                        "fillColor": "#2ecc71"
                    }
                },
                {
                    "type": "task",
                    "name": "ValidateCode"
                }
            ]
        },
        {
            "name": "ValidateCode",
            "actionSequence": [
                {
                    "type": "condition",
                    "formula": "Code1 == '🍉' && Code2 == '🍓' && Code3 == '🍎' && Code4 == '🍍'",
                    "thenTask": "LoginSuccess",
                    "elseTask": "LoginFailure"
                }
            ]
        },
        {
            "name": "LoginSuccess",
            "actionSequence": [
                {
                    "type": "log",
                    "message": "Login erfolgreich!",
                    "showToast": true
                },
                {
                    "type": "navigate",
                    "target": "lobby"
                }
            ]
        },
        {
            "name": "LoginFailure",
            "actionSequence": [
                {
                    "type": "log",
                    "message": "Falscher Code!",
                    "showToast": true
                },
                {
                    "type": "shake",
                    "target": "Slot1"
                },
                {
                    "type": "shake",
                    "target": "Slot2"
                },
                {
                    "type": "shake",
                    "target": "Slot3"
                },
                {
                    "type": "shake",
                    "target": "Slot4"
                },
                {
                    "type": "property",
                    "target": "Slot1",
                    "changes": {
                        "fillColor": "#16213e"
                    }
                },
                {
                    "type": "property",
                    "target": "Slot2",
                    "changes": {
                        "fillColor": "#16213e"
                    }
                },
                {
                    "type": "property",
                    "target": "Slot3",
                    "changes": {
                        "fillColor": "#16213e"
                    }
                },
                {
                    "type": "property",
                    "target": "Slot4",
                    "changes": {
                        "fillColor": "#16213e"
                    }
                },
                {
                    "type": "calculate",
                    "formula": "''",
                    "resultVariable": "Code1"
                },
                {
                    "type": "calculate",
                    "formula": "''",
                    "resultVariable": "Code2"
                },
                {
                    "type": "calculate",
                    "formula": "''",
                    "resultVariable": "Code3"
                },
                {
                    "type": "calculate",
                    "formula": "''",
                    "resultVariable": "Code4"
                }
            ]
        }
    ],
    "variables": [
        {
            "name": "Code1",
            "value": ""
        },
        {
            "name": "Code2",
            "value": ""
        },
