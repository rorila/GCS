{
    "meta": {
        "name": "Table Inspector",
        "version": "1.0.2"
    },
    "objects": [
        {
            "className": "TLabel",
            "name": "HeaderLabel",
            "text": "Tabellen-Konfiguration",
            "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "color": "#ffcc00",
                "marginBottom": 12
            }
        },
        {
            "className": "TDropdown",
            "name": "data",
            "label": "Datenbasis (Variable)",
            "selectedValue": "${selectedObject.data}",
            "options": "${availableVariablesAsTokens}",
            "placeholder": "-- Variable wählen --",
            "hint": "Wähle eine GCS Variable als Datenquelle."
        },
        {
            "className": "TEdit",
            "name": "columns",
            "label": "Spalten (JSON)",
            "text": "${selectedObject.columns}",
            "hint": "[{\"field\":\"id\", \"label\":\"ID\"}] - Leer lassen für Auto-Spalten."
        },
        {
            "className": "TNumberInput",
            "name": "rowHeight",
            "label": "Zeilenhöhe (px)",
            "value": "${selectedObject.rowHeight}"
        },
        {
            "className": "TCheckbox",
            "name": "showHeader",
            "label": "Kopfzeile zeigen",
            "checked": "${selectedObject.showHeader}"
        },
        {
            "className": "TCheckbox",
            "name": "striped",
            "label": "Zebra-Tabelle",
            "checked": "${selectedObject.striped}"
        }
    ]
}