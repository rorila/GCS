{
    "meta": {
        "name": "Variable Inspector",
        "version": "1.3.0"
    },
    "objects": [
        {
            "className": "TLabel",
            "name": "TitleLabel",
            "text": "📦 Variable: ${selectedObject.name}",
            "style": {
                "fontSize": 16,
                "fontWeight": "bold",
                "color": "#9cdcfe",
                "marginBottom": 16
            }
        },
        {
            "className": "TLabel",
            "name": "HeaderGeneral",
            "text": "📋 STAMMDATEN",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TLabel",
            "name": "NameLabel",
            "text": "Name:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "name",
            "text": "${selectedObject.name}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "TypeLabel",
            "text": "Datentyp:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TDropdown",
            "name": "variableType",
            "options": [
                "integer",
                "real",
                "string",
                "boolean",
                "list",
                "timer",
                "threshold",
                "trigger",
                "random",
                "range",
                "object_list"
            ],
            "selectedValue": "${selectedObject.variableType}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "HeaderValues",
            "text": "💎 DATEN & WERTE",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TLabel",
            "name": "ValueLabel",
            "text": "Aktueller Wert:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "value",
            "text": "${selectedObject.value}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "DefaultValueLabel",
            "text": "Standardwert (Reset):",
            "visible": "${selectedObject.variableType !== 'timer' && selectedObject.variableType !== 'random' && selectedObject.variableType !== 'range'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "defaultValue",
            "text": "${selectedObject.defaultValue}",
            "visible": "${selectedObject.variableType !== 'timer' && selectedObject.variableType !== 'random' && selectedObject.variableType !== 'range'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "ThresholdLabel",
            "text": "Schwellenwert (Threshold):",
            "visible": "${selectedObject.variableType === 'threshold'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "threshold",
            "value": "${selectedObject.threshold}",
            "visible": "${selectedObject.variableType === 'threshold'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "TriggerLabel",
            "text": "Trigger-Wert:",
            "visible": "${selectedObject.variableType === 'trigger'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "triggerValue",
            "text": "${selectedObject.triggerValue}",
            "visible": "${selectedObject.variableType === 'trigger'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "MaxIntervalLabel",
            "text": "Intervall (ms):",
            "visible": "${selectedObject.variableType === 'timer'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "maxInterval",
            "value": "${selectedObject.maxInterval}",
            "visible": "${selectedObject.variableType === 'timer'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TCheckbox",
            "name": "enabled",
            "checked": "${selectedObject.enabled}",
            "label": "Aktiviert (Timer)",
            "visible": "${selectedObject.variableType === 'timer'}",
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TCheckbox",
            "name": "isInteger",
            "checked": "${selectedObject.isInteger}",
            "label": "Ganzzahlen (Integer)",
            "visible": "${selectedObject.variableType === 'range' || selectedObject.variableType === 'random'}",
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "MinLabel",
            "text": "Minimum:",
            "visible": "${selectedObject.variableType === 'range' || selectedObject.variableType === 'random'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "min",
            "value": "${selectedObject.min}",
            "visible": "${selectedObject.variableType === 'range' || selectedObject.variableType === 'random'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "MaxLabel",
            "text": "Maximum:",
            "visible": "${selectedObject.variableType === 'range' || selectedObject.variableType === 'random'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "max",
            "value": "${selectedObject.max}",
            "visible": "${selectedObject.variableType === 'range' || selectedObject.variableType === 'random'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "HeaderScope",
            "text": "🌍 GÜLTIGKEIT & SICHTBARKEIT",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TLabel",
            "name": "ScopeLabel",
            "text": "Scope:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TDropdown",
            "name": "scope",
            "options": [
                "global",
                "stage"
            ],
            "selectedValue": "${selectedObject.scope}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        }
    ]
}