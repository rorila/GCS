{
    "meta": {
        "name": "Variable Inspector",
        "version": "1.2.1"
    },
    "objects": [
        {
            "className": "TLabel",
            "name": "TitleLabel",
            "text": "📦 Variable: ${selectedObject.VarName}",
            "style": {
                "fontSize": 16,
                "fontWeight": "bold",
                "color": "#9cdcfe",
                "marginBottom": 16
            }
        },
        {
            "className": "TLabel",
            "name": "HeaderGeneral",
            "text": "📋 STAMMDATEN",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TLabel",
            "name": "NameLabel",
            "text": "Name:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "VarName",
            "text": "${selectedObject.VarName}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "TypeLabel",
            "text": "Datentyp:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TDropdown",
            "name": "VarType",
            "options": [
                "integer",
                "real",
                "string",
                "boolean",
                "list",
                "timer",
                "threshold",
                "trigger",
                "random",
                "range",
                "object_list"
            ],
            "selectedValue": "${selectedObject.VarType}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "DescriptionLabel",
            "text": "Beschreibung:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "Description",
            "text": "${selectedObject.Description}",
            "width": 30,
            "height": 3,
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "HeaderValues",
            "text": "💎 DATEN & WERTE",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TLabel",
            "name": "ValueLabel",
            "text": "Aktueller Wert:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "Value",
            "text": "${selectedObject.Value}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "InitialValueLabel",
            "text": "Initialwert (Reset):",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "InitialValue",
            "text": "${selectedObject.InitialValue}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "ThresholdLabel",
            "text": "Schwellenwert (Threshold):",
            "visible": "${selectedObject.VarType === 'threshold'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Threshold",
            "value": "${selectedObject.Threshold}",
            "visible": "${selectedObject.VarType === 'threshold'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "TriggerLabel",
            "text": "Trigger-Wert:",
            "visible": "${selectedObject.VarType === 'trigger'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "TriggerValue",
            "text": "${selectedObject.TriggerValue}",
            "visible": "${selectedObject.VarType === 'trigger'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "DurationLabel",
            "text": "Dauer (ms):",
            "visible": "${selectedObject.VarType === 'timer'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Duration",
            "value": "${selectedObject.Duration}",
            "visible": "${selectedObject.VarType === 'timer'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "HoursLabel",
            "text": "Stunden:",
            "visible": "${selectedObject.VarType === 'timer'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Hours",
            "value": "${selectedObject.Hours}",
            "visible": "${selectedObject.VarType === 'timer'}",
            "width": 10,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "MinutesLabel",
            "text": "Minuten:",
            "visible": "${selectedObject.VarType === 'timer'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Minutes",
            "value": "${selectedObject.Minutes}",
            "visible": "${selectedObject.VarType === 'timer'}",
            "width": 10,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "SecondsLabel",
            "text": "Sekunden:",
            "visible": "${selectedObject.VarType === 'timer'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Seconds",
            "value": "${selectedObject.Seconds}",
            "visible": "${selectedObject.VarType === 'timer'}",
            "width": 10,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TCheckbox",
            "name": "IsInteger",
            "checked": "${selectedObject.IsInteger}",
            "label": "Ganzzahlen (Integer)",
            "visible": "${selectedObject.VarType === 'range' || selectedObject.VarType === 'random'}",
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "MinLabel",
            "text": "Minimum:",
            "visible": "${selectedObject.VarType === 'range' || selectedObject.VarType === 'random'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Min",
            "value": "${selectedObject.Min}",
            "visible": "${selectedObject.VarType === 'range' || selectedObject.VarType === 'random'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "MaxLabel",
            "text": "Maximum:",
            "visible": "${selectedObject.VarType === 'range' || selectedObject.VarType === 'random'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "Max",
            "value": "${selectedObject.Max}",
            "visible": "${selectedObject.VarType === 'range' || selectedObject.VarType === 'random'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "SearchValueLabel",
            "text": "Suchwert (für onContains):",
            "visible": "${selectedObject.VarType === 'list' || selectedObject.VarType === 'object_list'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "SearchValue",
            "text": "${selectedObject.SearchValue}",
            "visible": "${selectedObject.VarType === 'list' || selectedObject.VarType === 'object_list'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "SearchPropertyLabel",
            "text": "Such-Eigenschaft (für Objektsuche):",
            "visible": "${selectedObject.VarType === 'object_list'}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "SearchProperty",
            "text": "${selectedObject.SearchProperty}",
            "visible": "${selectedObject.VarType === 'object_list'}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "HeaderScope",
            "text": "🌍 GÜLTIGKEIT & SICHTBARKEIT",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TLabel",
            "name": "ScopeLabel",
            "text": "Scope:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TDropdown",
            "name": "Scope",
            "options": [
                "global",
                "stage"
            ],
            "selectedValue": "${selectedObject.Scope}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 8
            }
        },
        {
            "className": "TCheckbox",
            "name": "IsPublic",
            "checked": "${selectedObject.IsPublic}",
            "label": "Öffentlich (für andere Stages sichtbar)",
            "style": {
                "marginBottom": 12
            }
        }
    ]
}