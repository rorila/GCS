{
    "meta": {
        "name": "Smart Variable Inspector",
        "version": "1.1.0",
        "description": "Context-aware Inspector for Variables"
    },
    "objects": [
        {
            "className": "TLabel",
            "name": "TitleLabel",
            "text": "${selectedObject.name} (Variable)",
            "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "color": "#ffcc00",
                "marginBottom": 12
            }
        },
        {
            "className": "TDropdown",
            "name": "scope",
            "label": "Geltungsbereich (Scope)",
            "options": [
                {
                    "value": "global",
                    "label": "🌎 Global (Projektweit)"
                },
                {
                    "value": "stage",
                    "label": "🎭 Stage (Lokal)"
                }
            ],
            "selectedValue": "${selectedObject.scope}"
        },
        {
            "className": "TEdit",
            "name": "name",
            "label": "Name",
            "text": "${selectedObject.name}"
        },
        {
            "className": "TDropdown",
            "name": "type",
            "label": "Datentyp",
            "options": [
                {
                    "value": "integer",
                    "label": "Integer"
                },
                {
                    "value": "real",
                    "label": "Real"
                },
                {
                    "value": "string",
                    "label": "String"
                },
                {
                    "value": "boolean",
                    "label": "Boolean"
                },
                {
                    "value": "timer",
                    "label": "Timer (Zeitgeber)"
                },
                {
                    "value": "random",
                    "label": "Zufallszahl"
                },
                {
                    "value": "threshold",
                    "label": "Schwellenwert"
                },
                {
                    "value": "trigger",
                    "label": "Trigger (Auslöser)"
                },
                {
                    "value": "range",
                    "label": "Wertebereich"
                },
                {
                    "value": "object",
                    "label": "Objekt (Modell)"
                },
                {
                    "value": "object_list",
                    "label": "Objekt-Liste"
                },
                {
                    "value": "list",
                    "label": "Liste (Einfach)"
                },
                {
                    "value": "keystore",
                    "label": "KeyStore"
                },
                {
                    "value": "json",
                    "label": "JSON Daten"
                },
                {
                    "value": "any",
                    "label": "Beliebig (Any)"
                }
            ],
            "selectedValue": "${selectedObject.type}"
        },
        {
            "className": "TDropdown",
            "name": "objectModel",
            "label": "Datenmodell (Schema)",
            "visible": "${selectedObject.type === 'object' || selectedObject.type === 'object_list'}",
            "source": "availableModels",
            "placeholder": "Modell wählen...",
            "selectedValue": "${selectedObject.objectModel}"
        },
        {
            "className": "TNumberInput",
            "name": "interval",
            "label": "Intervall (ms)",
            "visible": "${selectedObject.type === 'timer'}",
            "value": "${selectedObject.interval}"
        },
        {
            "className": "TCheckbox",
            "name": "enabled",
            "label": "Aktiviert",
            "visible": "${selectedObject.type === 'timer'}",
            "checked": "${selectedObject.enabled}"
        },
        {
            "className": "TNumberInput",
            "name": "maxInterval",
            "label": "Max Wiederholungen (0=∞)",
            "visible": "${selectedObject.type === 'timer'}",
            "value": "${selectedObject.maxInterval}"
        },
        {
            "className": "TNumberInput",
            "name": "min",
            "label": "Minimum",
            "visible": "${selectedObject.type === 'random' || selectedObject.type === 'range'}",
            "value": "${selectedObject.min}"
        },
        {
            "className": "TNumberInput",
            "name": "max",
            "label": "Maximum",
            "visible": "${selectedObject.type === 'random' || selectedObject.type === 'range'}",
            "value": "${selectedObject.max}"
        },
        {
            "className": "TCheckbox",
            "name": "isInteger",
            "label": "Nur Ganzzahlen",
            "visible": "${selectedObject.type === 'random'}",
            "checked": "${selectedObject.isInteger}"
        },
        {
            "className": "TNumberInput",
            "name": "threshold",
            "label": "Schwellenwert",
            "visible": "${selectedObject.type === 'threshold'}",
            "value": "${selectedObject.threshold}"
        },
        {
            "className": "TEdit",
            "name": "triggerValue",
            "label": "Auslöser-Wert",
            "visible": "${selectedObject.type === 'trigger'}",
            "text": "${selectedObject.triggerValue}"
        },
        {
            "className": "TEdit",
            "name": "defaultValue",
            "label": "Standardwert",
            "text": "${selectedObject.defaultValue}"
        },
        {
            "className": "TEdit",
            "name": "value",
            "label": "Aktueller Wert",
            "text": "${selectedObject.value}"
        },
        {
            "className": "TButton",
            "name": "DeleteButton",
            "caption": "🗑️ Variable löschen",
            "action": "delete",
            "style": {
                "backgroundColor": "#c82333",
                "color": "#fff",
                "marginTop": 20
            }
        }
    ]
}