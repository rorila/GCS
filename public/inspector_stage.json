{
    "meta": {
        "name": "Stage Inspector",
        "version": "2.0.0",
        "description": "Inspector for Stage/Project properties"
    },
    "objects": [
        {
            "className": "TLabel",
            "name": "TitleLabel",
            "text": "${(activeStage && activeStage.name) || 'Projekt'} Einstellungen",
            "style": {
                "fontSize": 16,
                "fontWeight": "bold",
                "color": "#fff",
                "marginBottom": 16
            }
        },
        {
            "className": "TLabel",
            "name": "StageTypeLabel",
            "text": "Stage Typ:",
            "style": {
                "fontSize": 12,
                "color": "#aaa",
                "marginTop": 8
            }
        },
        {
            "className": "TSelect",
            "name": "activeStage.typeInput",
            "selectedValue": "${(activeStage && activeStage.type) || 'standard'}",
            "options": [
                "standard",
                "splash",
                "main",
                "template"
            ],
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "InheritanceLabel",
            "text": "Erbt von (Template):",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TSelect",
            "name": "activeStage.inheritsFromInput",
            "selectedValue": "${(activeStage && activeStage.inheritsFrom) || ''}",
            "source": "stages",
            "allowEmpty": true,
            "emptyLabel": "-- Kein Template --",
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "StageNameLabel",
            "text": "Stage Name:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "activeStage.nameInput",
            "text": "${(activeStage && activeStage.name) || ''}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "GameNameLabel",
            "text": "Spiel Name (Global):",
            "visible": "${activeStage && activeStage.type === 'main' ? true : false}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "activeStage.gameNameInput",
            "text": "${(activeStage && activeStage.gameName) || selectedObject.meta.name}",
            "visible": "${activeStage && activeStage.type === 'main' ? true : false}",
            "width": 30,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "AuthorLabel",
            "text": "Autor:",
            "visible": "${activeStage && activeStage.type === 'main' ? true : false}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "activeStage.authorInput",
            "text": "${(activeStage && activeStage.author) || selectedObject.meta.author}",
            "visible": "${activeStage && activeStage.type === 'main' ? true : false}",
            "width": 30,
            "height": 2,
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "DescriptionLabel",
            "text": "Beschreibung:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TEdit",
            "name": "activeStage.descriptionInput",
            "text": "${(activeStage && activeStage.description) || (selectedObject && selectedObject.meta && selectedObject.meta.description) || ''}",
            "placeholder": "Beschreibung eingeben...",
            "width": 30,
            "height": 4,
            "multiline": true
        },
        {
            "className": "TLabel",
            "name": "GridSettingsLabel",
            "text": "Raster Einstellungen (Stage)",
            "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "color": "#fff",
                "marginTop": 16,
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "ColumnsLabel",
            "text": "Spalten:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "activeStage.grid.colsInput",
            "value": "${(activeStage && activeStage.grid && activeStage.grid.cols) || selectedObject.stage.grid.cols}",
            "min": 10,
            "max": 100,
            "step": 1,
            "width": 14,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "RowsLabel",
            "text": "Zeilen:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "activeStage.grid.rowsInput",
            "value": "${(activeStage && activeStage.grid && activeStage.grid.rows) || selectedObject.stage.grid.rows}",
            "min": 10,
            "max": 100,
            "step": 1,
            "width": 14,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "CellSizeLabel",
            "text": "Zellgröße (px):",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "activeStage.grid.cellSizeInput",
            "value": "${(activeStage && activeStage.grid && activeStage.grid.cellSize) || selectedObject.stage.grid.cellSize}",
            "min": 5,
            "max": 50,
            "step": 1,
            "width": 14,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "ShowGridLabel",
            "text": "Raster anzeigen:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TCheckbox",
            "name": "activeStage.grid.visibleInput",
            "checked": "${(activeStage && activeStage.grid && activeStage.grid.visible !== undefined) ? activeStage.grid.visible : selectedObject.stage.grid.visible}",
            "label": "Rasterlinien zeichnen"
        },
        {
            "className": "TLabel",
            "name": "BackgroundColorLabel",
            "text": "Hintergrundfarbe:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TColorPicker",
            "name": "activeStage.grid.backgroundColorInput",
            "color": "${(activeStage && activeStage.grid && activeStage.grid.backgroundColor) || selectedObject.stage.grid.backgroundColor}",
            "width": 30,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "SplashSettingsLabel",
            "text": "Splash Screen Einstellungen",
            "visible": "${activeStage && activeStage.type === 'splash' ? true : false}",
            "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "color": "#fff",
                "marginTop": 16,
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "SplashDurationLabel",
            "text": "Anzeigedauer (ms):",
            "visible": "${activeStage && activeStage.type === 'splash' ? true : false}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "activeStage.durationInput",
            "value": "${(activeStage && activeStage.duration) || selectedObject.splashDuration || 3000}",
            "visible": "${activeStage && activeStage.type === 'splash' ? true : false}",
            "min": 500,
            "max": 10000,
            "step": 100,
            "width": 14,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "SplashAutoHideLabel",
            "text": "Auto-Fortsetzen:",
            "visible": "${activeStage && activeStage.type === 'splash' ? true : false}",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TCheckbox",
            "name": "activeStage.autoHideInput",
            "visible": "${activeStage && activeStage.type === 'splash' ? true : false}",
            "checked": "${(activeStage && activeStage.autoHide !== undefined) ? activeStage.autoHide : (selectedObject.splashAutoHide !== false)}",
            "label": "Nach Dauer zur nächsten Stage"
        },
        {
            "className": "TLabel",
            "name": "AnimationLabel",
            "text": "Animation",
            "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "color": "#fff",
                "marginTop": 16,
                "marginBottom": 8
            }
        },
        {
            "className": "TLabel",
            "name": "StartAnimationLabel",
            "text": "Start Animation:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TSelect",
            "name": "activeStage.startAnimationInput",
            "selectedValue": "${(activeStage && activeStage.startAnimation) || selectedObject.stage.startAnimation || 'none'}",
            "options": [
                "none",
                "UpLeft",
                "UpMiddle",
                "UpRight",
                "Left",
                "Right",
                "BottomLeft",
                "BottomMiddle",
                "BottomRight",
                "ChaosIn",
                "ChaosOut",
                "Matrix",
                "Random"
            ]
        },
        {
            "className": "TLabel",
            "name": "StartAnimationDurationLabel",
            "text": "Duration (ms):",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TNumberInput",
            "name": "activeStage.startAnimationDurationInput",
            "value": "${(activeStage && activeStage.startAnimationDuration) || selectedObject.stage.startAnimationDuration || 1000}",
            "min": 100,
            "max": 5000,
            "step": 100,
            "width": 14,
            "height": 2
        },
        {
            "className": "TLabel",
            "name": "StartAnimationEasingLabel",
            "text": "Easing:",
            "style": {
                "fontSize": 12,
                "color": "#aaa"
            }
        },
        {
            "className": "TSelect",
            "name": "activeStage.startAnimationEasingInput",
            "selectedValue": "${(activeStage && activeStage.startAnimationEasing) || selectedObject.stage.startAnimationEasing || 'easeOut'}",
            "options": [
                "linear",
                "easeIn",
                "easeOut",
                "easeInOut",
                "bounce",
                "elastic"
            ]
        },
        {
            "className": "TLabel",
            "name": "VariablesLabel",
            "text": "Variables",
            "style": {
                "fontSize": 14,
                "fontWeight": "bold",
                "color": "#fff",
                "marginTop": 24,
                "marginBottom": 8
            }
        },
        {
            "className": "TForEach",
            "name": "VariablesList",
            "source": "selectedObject.variables",
            "rowLayout": true,
            "template": [
                {
                    "className": "TLabel",
                    "name": "VarName_${index}",
                    "text": "${item.uiEmoji} ${item.name}:",
                    "style": {
                        "fontSize": 11,
                        "color": "#9cdcfe",
                        "minWidth": "100px",
                        "flex": "0 0 100px"
                    }
                },
                {
                    "className": "TLabel",
                    "name": "VarType_${index}",
                    "text": "${item.type}",
                    "style": {
                        "fontSize": 10,
                        "color": "#ce9178",
                        "minWidth": "50px",
                        "flex": "0 0 50px"
                    }
                },
                {
                    "className": "TLabel",
                    "name": "VarDefault_${index}",
                    "text": "= ${item.value !== undefined ? item.value : item.defaultValue}",
                    "style": {
                        "fontSize": 10,
                        "color": "#b5cea8",
                        "flex": "1"
                    }
                },
                {
                    "className": "TButton",
                    "name": "VarCopyBtn_${index}",
                    "caption": "📋",
                    "action": "copyVariable",
                    "variableIndex": "${index}",
                    "style": {
                        "flex": "0 0 28px",
                        "minWidth": "28px",
                        "padding": "4px",
                        "backgroundColor": "#17a2b8"
                    }
                },
                {
                    "className": "TButton",
                    "name": "VarEditBtn_${index}",
                    "caption": "✏️",
                    "action": "editVariable",
                    "variableIndex": "${index}",
                    "style": {
                        "flex": "0 0 28px",
                        "minWidth": "28px",
                        "padding": "4px"
                    }
                },
                {
                    "className": "TButton",
                    "name": "VarDeleteBtn_${index}",
                    "caption": "🗑️",
                    "action": "deleteVariable",
                    "variableIndex": "${index}",
                    "style": {
                        "flex": "0 0 28px",
                        "minWidth": "28px",
                        "padding": "4px",
                        "backgroundColor": "#c82333"
                    }
                }
            ]
        },
        {
            "className": "TButton",
            "name": "AddVariableButton",
            "caption": "+ Add Variable",
            "action": "addVariable",
            "style": {
                "backgroundColor": "#0e639c",
                "color": "#fff",
                "marginTop": 8
            }
        }
    ]
}