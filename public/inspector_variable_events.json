{
    "meta": {
        "name": "Variable Events Inspector",
        "version": "1.0.1",
        "description": "Context-aware Event Inspector for Variables"
    },
    "objects": [
        {
            "className": "TLabel",
            "name": "GeneralHeader",
            "text": "ALLGEMEINE EVENTS",
            "style": {
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 12,
                "marginBottom": 6
            }
        },
        {
            "className": "TDropdown",
            "name": "onValueChanged",
            "label": "Bei Wertänderung",
            "property": "events.onValueChanged",
            "source": "tasks",
            "placeholder": "Task wählen...",
            "selectedValue": "${selectedObject.events?.onValueChanged || selectedObject.onValueChanged || ''}"
        },
        {
            "className": "TDropdown",
            "name": "onValueEmpty",
            "label": "Wenn Wert leer",
            "property": "events.onValueEmpty",
            "source": "tasks",
            "placeholder": "Task wählen...",
            "selectedValue": "${selectedObject.events?.onValueEmpty || selectedObject.onValueEmpty || ''}"
        },
        {
            "className": "TLabel",
