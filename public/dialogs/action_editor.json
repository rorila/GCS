{
    "title": "Action Editor",
    "width": 500,
    "height": 450,
    "modal": true,
    "objects": [
        {
            "className": "TLabel",
            "name": "ActionNameLabel",
            "text": "Aktions-Name:",
            "style": {
                "fontSize": 12,
                "fontWeight": "bold",
                "color": "#fff",
                "marginBottom": 4
            }
        },
        {
            "className": "TEdit",
            "name": "NameInput",
            "text": "${dialogData.name}",
            "placeholder": "z.B. punkteErhoehen",
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "TypeLabel",
            "text": "Aktions-Typ:",
            "style": {
                "fontSize": 12,
                "fontWeight": "bold",
                "color": "#fff",
                "marginBottom": 4
            }
        },
        {
            "className": "TDropdown",
            "name": "ActionTypeSelect",
            "selectedValue": "${dialogData.type}",
            "options": "${getAllActionTypes()}",
            "style": {
                "marginBottom": 12
            }
        },
        {
            "className": "TLabel",
            "name": "ParamsHeader",
            "text": "Parameter:",
            "style": {
                "fontSize": 12,
                "fontWeight": "bold",
                "color": "#888",
                "marginTop": 8,
                "marginBottom": 4
            }
        },
        {
            "className": "TActionParams",
            "name": "ActionParams"
        }
    ],
    "footer": [
        {
            "className": "TButton",
            "name": "DeleteBtn",
            "caption": "🗑️ Löschen",
            "action": "delete",
            "style": {
                "backgroundColor": "#dc3545",
                "color": "#fff"
            }
        },
        {
            "className": "TButton",
            "name": "CancelBtn",
            "caption": "Abbrechen",
            "action": "cancel",
            "style": {
                "backgroundColor": "#444",
                "color": "#fff"
            }
        },
        {
            "className": "TButton",
            "name": "SaveBtn",
            "caption": "✅ Speichern",
            "action": "save",
            "style": {
                "backgroundColor": "#28a745",
                "color": "#fff",
                "flex": 1
            }
        }
    ]
}
